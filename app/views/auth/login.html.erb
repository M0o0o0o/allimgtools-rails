<% content_for :title, "Sign in — Allimgtools" %>
<% content_for :main_class, "min-h-screen" %>

<div class="min-h-screen flex">

  <%# Left panel — branding %>
  <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-primary to-secondary flex-col justify-between p-12 text-primary-content">
    <div>
      <%= link_to root_path, class: "flex items-center gap-2.5" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary-content" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="text-xl font-bold tracking-tight">allimgtools</span>
      <% end %>
    </div>

    <div class="space-y-8">
      <div>
        <h1 class="text-4xl font-bold leading-tight mb-3">
          All the image tools<br>you need, in one place.
        </h1>
        <p class="text-primary-content/70 text-lg">
          Compress, resize, convert, crop and more —<br>fast, free, and private.
        </p>
      </div>

      <ul class="space-y-3">
        <% [
          ["Compress", "Reduce file size without losing quality"],
          ["Resize",   "Change dimensions with aspect ratio control"],
          ["Convert",  "Switch between JPG, PNG, WebP formats"],
          ["Crop",     "Trim images to the exact size you need"],
          ["Rotate",   "Rotate images in any direction"],
          ["EXIF",     "Strip metadata for privacy"]
        ].each do |tool, desc| %>
          <li class="flex items-start gap-3">
            <div class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-primary-content/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <span class="font-semibold text-sm"><%= tool %></span>
              <span class="text-primary-content/60 text-sm"> — <%= desc %></span>
            </div>
          </li>
        <% end %>
      </ul>
    </div>

    <p class="text-primary-content/40 text-sm">
      &copy; <%= Date.today.year %> allimgtools. Free to use &middot; No data stored.
    </p>
  </div>

  <%# Right panel — login card %>
  <div class="w-full lg:w-1/2 flex items-center justify-center p-8 bg-base-100">
    <div class="w-full max-w-sm space-y-8">

      <%# Mobile logo %>
      <div class="lg:hidden flex justify-center">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="text-xl font-bold">allimgtools</span>
        <% end %>
      </div>

      <div class="text-center">
        <h2 class="text-2xl font-bold text-base-content">Welcome</h2>
        <p class="mt-1.5 text-base-content/50 text-sm">Sign in to access your account</p>
      </div>

      <div class="space-y-3">
        <%= button_to "/auth/google_oauth2",
              params: { origin: params[:return_to] },
              class: "btn btn-outline w-full gap-3 h-12 text-sm font-medium border-base-300 hover:border-base-content/30 hover:bg-base-200",
              data: { turbo: false } do %>
          <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        <% end %>
      </div>

      <p class="text-center text-xs text-base-content/35 leading-relaxed">
        By creating an account, you agree to our
        <%= link_to "Terms of Service", terms_path, class: "underline hover:text-base-content/60" %>
        and <%= link_to "Privacy Policy", privacy_path, class: "underline hover:text-base-content/60" %>.
      </p>

    </div>
  </div>

</div>
