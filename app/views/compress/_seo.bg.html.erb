<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        Компресирайте изображения онлайн —<br class="hidden sm:block"> Безплатно, бързо и без загуба на качество
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        Намалете размера на файловете на вашите изображения незабавно — без софтуер, без регистрация. Нашият безплатен онлайн компресор за изображения използва интелигентни алгоритми за компресия, за да свие вашите JPEG, PNG, GIF, WebP и AVIF файлове, като същевременно запазва визуалното качество. Използвайте плъзгача за качество, за да намерите идеалния баланс между размер на файла и яснота на изображението. Независимо дали оптимизирате снимки за уебсайт, подготвяте изображения за имейл или освобождавате място за съхранение, ще получите по-малки файлове за секунди.
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/compress_hero.png", alt: "Онлайн компресор за изображения — намалява размера на JPEG, PNG, WebP файлове, като същевременно запазва качеството", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Стъпка по стъпка</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Как да компресирате изображение онлайн</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Качете вашето изображение</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Плъзнете и пуснете или кликнете, за да изберете JPEG, JPG, PNG, GIF, WebP или AVIF файл.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Настройте плъзгача за качество</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Преместете плъзгача, за да контролирате нивото на компресия. По-ниските стойности произвеждат по-малки файлове; по-високите стойности запазват повече детайли.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Изтеглете вашето компресирано изображение</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Кликнете върху изтегляне и запазете оптимизирания си файл незабавно.</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Не е необходим акаунт. Вашите файлове никога не се съхраняват на нашите сървъри.
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Формати</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Компресирайте JPEG, PNG, WebP и други</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "Най-често срещаният формат за снимки. Идеален за изображения с висока разделителна способност с естествени цветове и градиенти." },
          { name: "PNG",        desc: "Поддържа прозрачност. Отличен за лога, екранни снимки и графики." },
          { name: "GIF",        desc: "Компресирайте анимирани или статични GIF файлове, без да губите кадри от анимацията." },
          { name: "WebP",       desc: "Модерният формат на Google. Компресира значително по-малко от JPEG при еквивалентно качество." },
          { name: "AVIF",       desc: "Формат от следващо поколение с отлична ефективност на компресия за съвременните браузъри." },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Target file size table ──────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Справка</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Компресирайте изображение до определен размер на файла</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Имате нужда от изображението си под определен размер — като 100KB, 200KB или 50KB? Използвайте плъзгача за качество, за да настроите фино компресията, докато не достигнете целта си. Ето бърза справка:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">Целеви размер</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">Препоръчителен диапазон на качество</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["Под 20 KB",  "10 – 25%"],
              ["Под 50 KB",  "25 – 40%"],
              ["Под 100 KB", "40 – 60%"],
              ["Под 200 KB", "60 – 75%"],
            ].each do |target, range| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= target %></td>
                <td class="text-sm text-base-content/60"><%= range %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">Резултатите варират в зависимост от съдържанието и размерите на оригиналното изображение. Настройте плъзгача и прегледайте преди изтегляне.</p>
    </div>

    <%# ── Website / WordPress ────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Уеб производителност</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Оптимизирайте изображения за вашия уебсайт или WordPress</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Скоростта на зареждане на страницата е един от факторите за класиране на Google — и изображенията обикновено са най-големият виновник. Неоптимизираните изображения забавят сайта ви, увеличават процента на отпадане и вредят на вашето SEO. Преди да качите изображения на уебсайта си, компресирайте ги, за да:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["Подобрете основните уеб показатели (Core Web Vitals)",       "Намалете резултатите на LCP (Largest Contentful Paint) чрез намаляване на размера на файловете с изображения."],
          ["Намалете използването на честотна лента",        "По-малките изображения означават по-бързо зареждане на страници, особено на мобилни устройства."],
          ["Преминете Google PageSpeed Insights","Повечето одити отбелязват некомпресираните изображения като основен проблем."],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200">
        <strong class="text-base-content font-semibold">Съвет за WordPress:</strong> Компресирайте изображенията си тук, преди да ги качите в медийната библиотека. Това избягва разчитането на сървърни плъгини и ви дава пълен контрол върху качеството на изхода.
      </div>
    </div>

    <%# ── Bulk compression ───────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Pro функция</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Групова компресия на изображения</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Трябва ли да компресирате няколко изображения наведнъж? Нашият инструмент за групова компресия ви позволява да качвате и обработвате няколко файла наведнъж — идеален за:
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["Електронна търговия",    "Компресирайте десетки продуктови изображения преди публикуване."],
          ["Публикации в блогове",    "Оптимизирайте основни изображения и вградени снимки в една партида."],
          ["Доставки",  "Изпращайте компресирани комплекти снимки по имейл или облачно хранилище."],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70
