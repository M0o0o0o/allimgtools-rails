<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        ऑनलाइन इमेज कंप्रेस करें —<br class="hidden sm:block"> मुफ्त, तेज़ और बिना गुणवत्ता खोए
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        अपनी छवियों का फ़ाइल आकार तुरंत कम करें — किसी सॉफ़्टवेयर या साइन-अप की आवश्यकता नहीं है। हमारा मुफ्त ऑनलाइन इमेज कंप्रेसर आपके JPEG, PNG, GIF, WebP और AVIF फ़ाइलों को दृश्य गुणवत्ता बनाए रखते हुए छोटा करने के लिए स्मार्ट कम्प्रेशन एल्गोरिदम का उपयोग करता है। फ़ाइल आकार और छवि स्पष्टता के बीच सही संतुलन खोजने के लिए गुणवत्ता स्लाइडर का उपयोग करें। चाहे आप किसी वेबसाइट के लिए फ़ोटो अनुकूलित कर रहे हों, ईमेल के लिए छवियां तैयार कर रहे हों, या स्टोरेज स्पेस खाली कर रहे हों, आपको कुछ ही सेकंड में छोटी फ़ाइलें मिल जाएंगी।
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/compress_hero.png", alt: "ऑनलाइन इमेज कंप्रेसर — JPEG, PNG, WebP फ़ाइल का आकार कम करें और गुणवत्ता बनाए रखें", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">चरण-दर-चरण</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ऑनलाइन इमेज को कैसे कंप्रेस करें</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">अपनी इमेज अपलोड करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">JPEG, JPG, PNG, GIF, WebP, या AVIF फ़ाइल को ड्रैग और ड्रॉप करें या चुनने के लिए क्लिक करें।</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">गुणवत्ता स्लाइडर समायोजित करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">कम्प्रेशन स्तर को नियंत्रित करने के लिए स्लाइडर को हिलाएं। कम मान छोटी फ़ाइलें बनाते हैं; उच्च मान अधिक विवरण बनाए रखते हैं।</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">अपनी कंप्रेस की गई इमेज डाउनलोड करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">डाउनलोड पर क्लिक करें और अपनी अनुकूलित फ़ाइल तुरंत सहेजें।</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        किसी खाते की आवश्यकता नहीं है। आपकी फ़ाइलें हमारे सर्वर पर कभी संग्रहीत नहीं होती हैं।
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">फ़ॉर्मेट</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">JPEG, PNG, WebP और अन्य को कंप्रेस करें</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "फ़ोटो के लिए सबसे सामान्य फ़ॉर्मेट। प्राकृतिक रंगों और ग्रेडिएंट वाली उच्च-रिज़ॉल्यूशन छवियों के लिए आदर्श।" },
          { name: "PNG",        desc: "पारदर्शिता का समर्थन करता है। लोगो, स्क्रीनशॉट और ग्राफ़िक्स के लिए बढ़िया।" },
          { name: "GIF",        desc: "एनिमेटेड या स्थिर GIF को एनिमेशन फ़्रेम खोए बिना कंप्रेस करें।" },
          { name: "WebP",       desc: "Google का आधुनिक फ़ॉर्मेट। समान गुणवत्ता पर JPEG की तुलना में काफी छोटा कंप्रेस करता है।" },
          { name: "AVIF",       desc: "आधुनिक ब्राउज़रों के लिए उत्कृष्ट कम्प्रेशन दक्षता वाला अगली पीढ़ी का फ़ॉर्मेट।" },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Target file size table ──────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">संदर्भ</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">एक इमेज को विशिष्ट फ़ाइल आकार में कंप्रेस करें</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        क्या आपको अपनी इमेज एक निश्चित आकार — जैसे 100KB, 200KB, या 50KB — से कम चाहिए? अपने लक्ष्य तक पहुँचने तक कम्प्रेशन को ठीक करने के लिए गुणवत्ता स्लाइडर का उपयोग करें। यहाँ एक त्वरित संदर्भ है:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">लक्ष्य आकार</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">अनुशंसित गुणवत्ता सीमा</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["20 KB से कम",  "10 – 25%"],
              ["50 KB से कम",  "25 – 40%"],
              ["100 KB से कम", "40 – 60%"],
              ["200 KB से कम", "60 – 75%"],
            ].each do |target, range| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= target %></td>
                <td class="text-sm text-base-content/60"><%= range %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">परिणाम मूल इमेज सामग्री और आयामों के आधार पर भिन्न होते हैं। डाउनलोड करने से पहले स्लाइडर को समायोजित करें और पूर्वावलोकन करें।</p>
    </div>

    <%# ── Website / WordPress ────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">वेब प्रदर्शन</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">अपनी वेबसाइट या वर्डप्रेस के लिए छवियों को अनुकूलित करें</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        पेज लोड गति Google के रैंकिंग कारकों में से एक है — और छवियां आमतौर पर सबसे बड़ी अपराधी होती हैं। अनुपयोगी छवियां आपकी साइट को धीमा करती हैं, बाउंस दर बढ़ाती हैं और आपके SEO को नुकसान पहुंचाती हैं। अपनी वेबसाइट पर छवियां अपलोड करने से पहले, उन्हें कंप्रेस करें ताकि:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["कोर वेब वाइटल्स में सुधार करें",       "इमेज फ़ाइल आकार कम करके LCP (Largest Contentful Paint) स्कोर कम करें।"],
          ["बैंडविड्थ उपयोग कम करें",        "छोटी छवियों का मतलब है तेज़ पेज लोड, खासकर मोबाइल पर।"],
          ["Google PageSpeed Insights पास करें","अधिकांश ऑडिट असंपीड़ित छवियों को एक प्रमुख समस्या के रूप में चिह्नित करते हैं।"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200">
        <strong class="text-base-content font-semibold">वर्डप्रेस टिप:</strong> मीडिया लाइब्रेरी में अपलोड करने से पहले अपनी छवियों को यहां कंप्रेस करें। यह सर्वर-साइड प्लगइन्स पर निर्भरता से बचाता है और आपको आउटपुट गुणवत्ता पर पूर्ण नियंत्रण देता है।
      </div>
    </div>

    <%# ── Bulk compression ───────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">प्रो सुविधा</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">बल्क इमेज कम्प्रेशन</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        एक साथ कई छवियों को कंप्रेस करने की आवश्यकता है? हमारा बल्क कम्प्रेशन टूल आपको एक साथ कई फ़ाइलें अपलोड और प्रोसेस करने देता है — इसके लिए एकदम सही है:
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["ई-कॉमर्स",    "प्रकाशित करने से पहले दर्जनों उत्पाद छवियों को कंप्रेस करें।"],
          ["ब्लॉग पोस्ट",    "एक बैच में फीचर्ड छवियों और इनलाइन फ़ोटो को अनुकूलित करें।"],
          ["डिलीवरेबल्स",  "ईमेल या क्लाउड स्टोरेज के माध्यम से कंप्रेस किए गए फोटो सेट भेजें।"],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= label %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-6 flex items-center justify-between gap-6">
        <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 pointer-events-none"></div>
        <div class="absolute right-8 bottom-0 h-14 w-14 rounded-full bg-white/5 pointer-events-none"></div>
        <div class="relative">
          <p class="font-bold text-white mb-0.5">बल्क प्रोसेसिंग प्रो पर उपलब्ध है</p>
          <p class="text-white/60 text-sm">एक क्लिक में कई फ़ाइलें प्रोसेस करें।</p>
        </div>
        <%= link_to pricing_path, class: "relative shrink-0 btn btn-sm bg-white text-primary hover:bg-white/90 border-0 font-semibold shadow-sm" do %>
          मुफ्त में शुरू करें →
        <% end %>
      </div>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">उपयोग के मामले</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">इमेज को कंप्रेस क्यों करें?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["वेबसाइटें और ब्लॉग",   "बड़ी छवियां धीमी-लोडिंग वाले पृष्ठों का #1 कारण हैं। अपलोड करने से पहले कंप्रेस करने से पेज का वजन कम होता है और सभी उपकरणों पर उपयोगकर्ता अनुभव बेहतर होता है।"],
          ["ईमेल अटैचमेंट",  "अधिकांश ईमेल क्लाइंट में 25 MB अटैचमेंट सीमा होती है। फ़ोटो को कंप्रेस करने से आकार प्रतिबंधों को पूरा किए बिना कई छवियां भेजना आसान हो जाता है।"],
          ["सोशल मीडिया",       "इंस्टाग्राम और फेसबुक जैसे प्लेटफॉर्म आपके अपलोड को फिर से कंप्रेस करते हैं, जिससे अक्सर गुणवत्ता खराब हो जाती है। अपनी तस्वीरों के दिखने के तरीके पर अधिक नियंत्रण बनाए रखने के लिए पहले से कंप्रेस करें।"],
          ["स्टोरेज और बैकअप",   "बड़े फोटो संग्रहों को संग्रहीत कर रहे हैं? छवियों को कंप्रेस करने से सामान्य देखने के आकार पर ध्यान देने योग्य गुणवत्ता हानि के बिना स्टोरेज आवश्यकताओं को काफी कम किया जा सकता है।"],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">अक्सर पूछे जाने वाले प्रश्न</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">अक्सर पूछे जाने वाले प्रश्न</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["क्या इमेज को कंप्रेस करने से उसकी गुणवत्ता कम हो जाती है?",
           "यह कम्प्रेशन स्तर पर निर्भर करता है। लॉसी कम्प्रेशन (JPEG, WebP) कुछ इमेज डेटा हटाता है — मध्यम सेटिंग्स पर, अंतर मानव आँख को मुश्किल से दिखाई देता है। डाउनलोड करने से पहले परिणामों का पूर्वावलोकन करने के लिए गुणवत्ता स्लाइडर का उपयोग करें।"],
          ["मैं एक इमेज को 100 KB से कम में कैसे कंप्रेस करूं?",
           "अपनी इमेज अपलोड करें, गुणवत्ता स्लाइड
