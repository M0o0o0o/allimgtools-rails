<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        Kompresuj Obrazy Online —<br class="hidden sm:block"> Bezpłatnie, Szybko i Bez Utraty Jakości
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        Natychmiast zmniejsz rozmiar plików swoich obrazów — bez oprogramowania, bez rejestracji. Nasz darmowy kompresor obrazów online wykorzystuje inteligentne algorytmy kompresji, aby zmniejszyć pliki JPEG, PNG, GIF, WebP i AVIF, zachowując jednocześnie jakość wizualną. Użyj suwaka jakości, aby znaleźć idealną równowagę między rozmiarem pliku a klarownością obrazu. Niezależnie od tego, czy optymalizujesz zdjęcia na stronę internetową, przygotowujesz obrazy do wiadomości e-mail, czy zwalniasz miejsce na dysku, uzyskasz mniejsze pliki w ciągu kilku sekund.
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/compress_hero.png", alt: "Kompresor obrazów online — zmniejsz rozmiar plików JPEG, PNG, WebP, zachowując jakość", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Krok po kroku</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Jak skompresować obraz online</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Prześlij swój obraz</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Przeciągnij i upuść lub kliknij, aby wybrać plik JPEG, JPG, PNG, GIF, WebP lub AVIF.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Dostosuj suwak jakości</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Przesuń suwak, aby kontrolować poziom kompresji. Niższe wartości dają mniejsze pliki; wyższe wartości zachowują więcej szczegółów.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Pobierz skompresowany obraz</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Kliknij pobierz i natychmiast zapisz zoptymalizowany plik.</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Nie wymagamy konta. Twoje pliki nigdy nie są przechowywane na naszych serwerach.
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Formaty</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Kompresuj JPEG, PNG, WebP i inne</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "Najpopularniejszy format zdjęć. Idealny do obrazów o wysokiej rozdzielczości z naturalnymi kolorami i gradientami." },
          { name: "PNG",        desc: "Obsługuje przezroczystość. Świetny do logo, zrzutów ekranu i grafik." },
          { name: "GIF",        desc: "Kompresuj animowane lub statyczne pliki GIF bez utraty klatek animacji." },
          { name: "WebP",       desc: "Nowoczesny format Google. Kompresuje znacznie mniejsze pliki niż JPEG przy równoważnej jakości." },
          { name: "AVIF",       desc: "Format nowej generacji o doskonałej wydajności kompresji dla nowoczesnych przeglądarek." },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Target file size table ──────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Referencje</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Skompresuj obraz do określonego rozmiaru pliku</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Potrzebujesz obrazu o określonym rozmiarze — np. poniżej 100KB, 200KB lub 50KB? Użyj suwaka jakości, aby precyzyjnie dostosować kompresję, aż osiągniesz swój cel. Oto szybki przewodnik:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">Docelowy Rozmiar</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">Zalecany Zakres Jakości</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["Poniżej 20 KB",  "10 – 25%"],
              ["Poniżej 50 KB",  "25 – 40%"],
              ["Poniżej 100 KB", "40 – 60%"],
              ["Poniżej 200 KB", "60 – 75%"],
            ].each do |target, range| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= target %></td>
                <td class="text-sm text-base-content/60"><%= range %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">Wyniki różnią się w zależności od oryginalnej zawartości i wymiarów obrazu. Dostosuj suwak i podglądaj przed pobraniem.</p>
    </div>

    <%# ── Website / WordPress ────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Wydajność Strony Internetowej</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Optymalizuj obrazy dla swojej strony internetowej lub WordPressa</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Szybkość ładowania strony jest jednym z czynników rankingowych Google — a obrazy są zazwyczaj największym winowajcą. Niezoptymalizowane obrazy spowalniają Twoją witrynę, zwiększają współczynnik odrzuceń i szkodzą Twojemu SEO. Przed przesłaniem obrazów na swoją stronę internetową skompresuj je, aby:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["Popraw Core Web Vitals",       "Obniż wyniki LCP (Largest Contentful Paint) poprzez zmniejszenie rozmiarów plików obrazów."],
          ["Zmniejsz zużycie przepustowości",        "Mniejsze obrazy oznaczają szybsze ładowanie stron, zwłaszcza na urządzeniach mobilnych."],
          ["Przejdź testy Google PageSpeed Insights","Większość audytów wskazuje nieskompresowane obrazy jako główny problem."],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200">
        <strong class="text-base-content font-semibold">Wskazówka WordPress:</strong> Skompresuj swoje obrazy tutaj przed przesłaniem do biblioteki mediów. Pozwala to uniknąć polegania na wtyczkach po stronie serwera i daje pełną kontrolę nad jakością wyjściową.
      </div>
    </div>

    <%# ── Bulk compression ───────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Funkcja Pro</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Masowa kompresja obrazów</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Potrzebujesz skompresować wiele obrazów jednocześnie? Nasze narzędzie do masowej kompresji pozwala przesyłać i przetwarzać kilka plików za jednym razem — idealne dla:
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["E-commerce",    "Skompresuj dziesiątki zdjęć produktów przed publikacją."],
          ["Posty na blogu",    "Zoptymalizuj wyróżnione obrazy i zdjęcia w tekście w jednej partii."],
          ["Materiały do dostarczenia",  "Wysyłaj skompresowane zestawy zdjęć e-mailem lub przez pamięć w chmurze."],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= label %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-6 flex items-center justify-between gap-6">
        <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 pointer-events-none"></div>
        <div class="absolute right-8 bottom-0 h-14 w-14 rounded-full bg-white/5 pointer-events-none"></div>
        <div class="relative">
          <p class="font-bold text-white mb-0.5">Masowe przetwarzanie jest dostępne w wersji Pro</p>
          <p class="text-white/60 text-sm">Przetwarzaj wiele plików jednym kliknięciem.</p>
        </div>
        <%= link_to pricing_path, class: "relative shrink-0 btn btn-sm bg-white text-primary hover:bg-white/90 border-0 font-semibold shadow-sm" do %>
          Rozpocznij za darmo →
        <% end %>
      </div>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Przypadki użycia</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Dlaczego kompresować obrazy?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-
