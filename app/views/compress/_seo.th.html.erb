<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        บีบอัดรูปภาพออนไลน์ —<br class="hidden sm:block"> ฟรี รวดเร็ว &amp; ไม่สูญเสียคุณภาพ
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        ลดขนาดไฟล์รูปภาพของคุณได้ทันที — ไม่ต้องใช้ซอฟต์แวร์ ไม่ต้องลงทะเบียน โปรแกรมบีบอัดรูปภาพออนไลน์ฟรีของเราใช้ขั้นตอนวิธีบีบอัดอัจฉริยะเพื่อลดขนาดไฟล์ JPEG, PNG, GIF, WebP และ AVIF ของคุณ โดยยังคงคุณภาพของภาพไว้ ใช้แถบเลื่อนคุณภาพเพื่อหาสมดุลที่สมบูรณ์แบบระหว่างขนาดไฟล์และความคมชัดของภาพ ไม่ว่าคุณจะปรับแต่งรูปภาพสำหรับเว็บไซต์ เตรียมรูปภาพสำหรับอีเมล หรือเพิ่มพื้นที่เก็บข้อมูล คุณจะได้ไฟล์ที่มีขนาดเล็กลงในไม่กี่วินาที
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/compress_hero.png", alt: "โปรแกรมบีบอัดรูปภาพออนไลน์ — ลดขนาดไฟล์ JPEG, PNG, WebP โดยยังคงคุณภาพไว้", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ทีละขั้นตอน</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">วิธีบีบอัดรูปภาพออนไลน์</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">อัปโหลดรูปภาพของคุณ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">ลากและวาง หรือคลิกเพื่อเลือกไฟล์ JPEG, JPG, PNG, GIF, WebP หรือ AVIF</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">ปรับแถบเลื่อนคุณภาพ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">เลื่อนแถบเลื่อนเพื่อควบคุมระดับการบีบอัด ค่าที่ต่ำกว่าจะสร้างไฟล์ที่เล็กลง; ค่าที่สูงกว่าจะคงรายละเอียดไว้มากขึ้น</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">ดาวน์โหลดรูปภาพที่บีบอัดของคุณ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">คลิกดาวน์โหลดและบันทึกไฟล์ที่ปรับแต่งแล้วของคุณได้ทันที</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        ไม่ต้องมีบัญชี ไฟล์ของคุณจะไม่ถูกเก็บไว้บนเซิร์ฟเวอร์ของเรา
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">รูปแบบไฟล์</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">บีบอัด JPEG, PNG, WebP &amp; อื่นๆ</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "รูปแบบที่พบบ่อยที่สุดสำหรับภาพถ่าย เหมาะสำหรับภาพความละเอียดสูงที่มีสีและไล่ระดับสีที่เป็นธรรมชาติ" },
          { name: "PNG",        desc: "รองรับความโปร่งใส เหมาะสำหรับโลโก้ ภาพหน้าจอ และกราฟิก" },
          { name: "GIF",        desc: "บีบอัด GIF แบบเคลื่อนไหวหรือแบบคงที่โดยไม่สูญเสียเฟรมแอนิเมชัน" },
          { name: "WebP",       desc: "รูปแบบที่ทันสมัยของ Google บีบอัดได้เล็กกว่า JPEG อย่างมากที่คุณภาพเทียบเท่ากัน" },
          { name: "AVIF",       desc: "รูปแบบยุคใหม่ที่มีประสิทธิภาพการบีบอัดยอดเยี่ยมสำหรับเบราว์เซอร์สมัยใหม่" },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Target file size table ──────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ข้อมูลอ้างอิง</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">บีบอัดรูปภาพให้มีขนาดไฟล์ที่ต้องการ</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        ต้องการรูปภาพของคุณให้มีขนาดต่ำกว่าที่กำหนด — เช่น 100KB, 200KB หรือ 50KB? ใช้แถบเลื่อนคุณภาพเพื่อปรับแต่งการบีบอัดจนกว่าจะถึงเป้าหมายของคุณ นี่คือข้อมูลอ้างอิงอย่างรวดเร็ว:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">ขนาดเป้าหมาย</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">ช่วงคุณภาพที่แนะนำ</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["ต่ำกว่า 20 KB",  "10 – 25%"],
              ["ต่ำกว่า 50 KB",  "25 – 40%"],
              ["ต่ำกว่า 100 KB", "40 – 60%"],
              ["ต่ำกว่า 200 KB", "60 – 75%"],
            ].each do |target, range| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= target %></td>
                <td class="text-sm text-base-content/60"><%= range %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">ผลลัพธ์จะแตกต่างกันไปขึ้นอยู่กับเนื้อหาและขนาดของรูปภาพต้นฉบับ ปรับแถบเลื่อนและดูตัวอย่างก่อนดาวน์โหลด</p>
    </div>

    <%# ── Website / WordPress ────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ประสิทธิภาพของเว็บ</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ปรับแต่งรูปภาพสำหรับเว็บไซต์หรือ WordPress ของคุณ</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        ความเร็วในการโหลดหน้าเว็บเป็นหนึ่งในปัจจัยการจัดอันดับของ Google — และรูปภาพมักเป็นตัวการที่ใหญ่ที่สุด รูปภาพที่ไม่ได้ปรับแต่งจะทำให้เว็บไซต์ของคุณช้าลง เพิ่มอัตราการตีกลับ และส่งผลเสียต่อ SEO ของคุณ ก่อนอัปโหลดรูปภาพไปยังเว็บไซต์ของคุณ ให้บีบอัดรูปภาพเพื่อ:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["ปรับปรุง Core Web Vitals",       "ลดคะแนน LCP (Largest Contentful Paint) โดยการลดขนาดไฟล์รูปภาพ"],
          ["ลดการใช้แบนด์วิดท์",        "รูปภาพที่เล็กลงหมายถึงการโหลดหน้าที่เร็วขึ้น โดยเฉพาะบนมือถือ"],
          ["ผ่าน Google PageSpeed Insights","การตรวจสอบส่วนใหญ่จะระบุรูปภาพที่ไม่ได้บีบอัดว่าเป็นปัญหาหลัก"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200">
        <strong class="text-base-content font-semibold">เคล็ดลับ WordPress:</strong> บีบอัดรูปภาพของคุณที่นี่ก่อนอัปโหลดไปยังคลังสื่อ สิ่งนี้จะช่วยหลีกเลี่ยงการพึ่งพาปลั๊กอินฝั่งเซิร์ฟเวอร์และให้คุณควบคุมคุณภาพผลลัพธ์ได้อย่างเต็มที่
      </div>
    </div>

    <%# ── Bulk compression ───────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">คุณสมบัติระดับโปร</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">การบีบอัดรูปภาพจำนวนมาก</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        ต้องการบีบอัดรูปภาพหลายรูปพร้อมกันหรือไม่? เครื่องมือบีบอัดจำนวนมากของเราช่วยให้คุณอัปโหลดและประมวลผลไฟล์หลายไฟล์ได้ในครั้งเดียว — เหมาะสำหรับ:
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["อีคอมเมิร์ซ",    "บีบอัดรูปภาพสินค้าหลายสิบรูปก่อนเผยแพร่"],
          ["โพสต์บล็อก",    "ปรับแต่งรูปภาพเด่นและรูปภาพในเนื้อหาเป็นชุดเดียว"],
          ["งานที่ต้องส่ง",  "ส่งชุดรูปภาพที่บีบอัดผ่านอีเมลหรือที่เก็บข้อมูลบนคลาวด์"],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= label %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-6 flex items-center justify-between gap-6">
        <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 pointer-events-none"></div>
        <div class="absolute right-8 bottom-0 h-14 w-14 rounded-full bg-white/5 pointer-events-none"></div>
        <div class="relative">
          <p class="font-bold text-white mb-0.5">การประมวลผลจำนวนมากมีให้ใช้งานในเวอร์ชัน Pro</p>
          <p class="text-white/60 text-sm">ประมวลผลหลายไฟล์ได้ในคลิกเดียว</p>
        </div>
        <%= link_
