<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        Nén ảnh trực tuyến —<br class="hidden sm:block"> Miễn phí, Nhanh chóng &amp; Không giảm chất lượng
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        Giảm kích thước tệp ảnh của bạn ngay lập tức — không cần phần mềm, không cần đăng ký. Công cụ nén ảnh trực tuyến miễn phí của chúng tôi sử dụng các thuật toán nén thông minh để thu nhỏ các tệp JPEG, PNG, GIF, WebP và AVIF của bạn trong khi vẫn giữ nguyên chất lượng hình ảnh. Sử dụng thanh trượt chất lượng để tìm sự cân bằng hoàn hảo giữa kích thước tệp và độ rõ nét của ảnh. Cho dù bạn đang tối ưu hóa ảnh cho trang web, chuẩn bị ảnh để gửi email hay giải phóng dung lượng lưu trữ, bạn sẽ nhận được các tệp nhỏ hơn chỉ trong vài giây.
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/compress_hero.png", alt: "Công cụ nén ảnh trực tuyến — giảm kích thước tệp JPEG, PNG, WebP trong khi vẫn giữ nguyên chất lượng", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Từng bước</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Cách nén ảnh trực tuyến</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Tải ảnh của bạn lên</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Kéo và thả hoặc nhấp để chọn tệp JPEG, JPG, PNG, GIF, WebP hoặc AVIF.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Điều chỉnh thanh trượt chất lượng</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Di chuyển thanh trượt để kiểm soát mức độ nén. Giá trị thấp hơn tạo ra các tệp nhỏ hơn; giá trị cao hơn giữ lại nhiều chi tiết hơn.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Tải ảnh đã nén của bạn xuống</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Nhấp tải xuống và lưu tệp đã tối ưu hóa của bạn ngay lập tức.</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Không cần tài khoản. Các tệp của bạn không bao giờ được lưu trữ trên máy chủ của chúng tôi.
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Định dạng</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Nén JPEG, PNG, WebP &amp; Nhiều hơn nữa</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "Định dạng phổ biến nhất cho ảnh. Lý tưởng cho ảnh độ phân giải cao với màu sắc và gradient tự nhiên." },
          { name: "PNG",        desc: "Hỗ trợ độ trong suốt. Tuyệt vời cho logo, ảnh chụp màn hình và đồ họa." },
          { name: "GIF",        desc: "Nén GIF động hoặc tĩnh mà không làm mất khung hình động." },
          { name: "WebP",       desc: "Định dạng hiện đại của Google. Nén nhỏ hơn đáng kể so với JPEG ở chất lượng tương đương." },
          { name: "AVIF",       desc: "Định dạng thế hệ tiếp theo với hiệu quả nén tuyệt vời cho các trình duyệt hiện đại." },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Target file size table ──────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Tham khảo</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Nén ảnh đến một kích thước tệp cụ thể</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Cần ảnh của bạn có kích thước dưới một mức nhất định — như 100KB, 200KB hoặc 50KB? Sử dụng thanh trượt chất lượng để tinh chỉnh độ nén cho đến khi bạn đạt được mục tiêu. Dưới đây là bảng tham khảo nhanh:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">Kích thước mục tiêu</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">Phạm vi chất lượng đề xuất</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["Dưới 20 KB",  "10 – 25%"],
              ["Dưới 50 KB",  "25 – 40%"],
              ["Dưới 100 KB", "40 – 60%"],
              ["Dưới 200 KB", "60 – 75%"],
            ].each do |target, range| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= target %></td>
                <td class="text-sm text-base-content/60"><%= range %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">Kết quả khác nhau tùy thuộc vào nội dung và kích thước ảnh gốc. Điều chỉnh thanh trượt và xem trước trước khi tải xuống.</p>
    </div>

    <%# ── Website / WordPress ────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Hiệu suất Web</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Tối ưu hóa ảnh cho trang web hoặc WordPress của bạn</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Tốc độ tải trang là một trong những yếu tố xếp hạng của Google — và hình ảnh thường là nguyên nhân lớn nhất. Ảnh không được tối ưu hóa làm chậm trang web của bạn, tăng tỷ lệ thoát và gây hại cho SEO của bạn. Trước khi tải ảnh lên trang web của bạn, hãy nén chúng để:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["Cải thiện Core Web Vitals",       "Giảm điểm LCP (Largest Contentful Paint) bằng cách giảm kích thước tệp ảnh."],
          ["Giảm mức sử dụng băng thông",        "Ảnh nhỏ hơn có nghĩa là tải trang nhanh hơn, đặc biệt trên thiết bị di động."],
          ["Vượt qua Google PageSpeed Insights","Hầu hết các cuộc kiểm tra đều gắn cờ ảnh không nén là một vấn đề hàng đầu."],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200">
        <strong class="text-base-content font-semibold">Mẹo WordPress:</strong> Nén ảnh của bạn tại đây trước khi tải lên thư viện phương tiện. Điều này tránh phụ thuộc vào các plugin phía máy chủ và cho phép bạn kiểm soát hoàn toàn chất lượng đầu ra.
      </div>
    </div>

    <%# ── Bulk compression ───────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Tính năng Pro</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Nén ảnh hàng loạt</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Cần nén nhiều ảnh cùng lúc? Công cụ nén hàng loạt của chúng tôi cho phép bạn tải lên và xử lý nhiều tệp cùng một lúc — hoàn hảo cho:
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["Thương mại điện tử",    "Nén hàng chục ảnh sản phẩm trước khi xuất bản."],
          ["Bài đăng blog",    "Tối ưu hóa ảnh nổi bật và ảnh nội dung trong một lần."],
          ["Sản phẩm bàn giao",  "Gửi các bộ ảnh đã nén qua email hoặc lưu trữ đám mây."],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= label %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-6 flex items-center justify-between gap-6">
        <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 pointer-events-none"></div>
        <div class="absolute right-8 bottom-0 h-14 w-14 rounded-full bg-white/5 pointer-events-none"></div>
        <div class="relative">
          <p class="font-bold text-white mb-0.5">Xử lý hàng loạt có sẵn trên gói Pro</p>
          <p class="text-white/60 text-sm">Xử lý nhiều tệp chỉ với một cú nhấp chuột.</p>
        </div>
        <%= link_to pricing_path, class: "relative shrink-0 btn btn-sm bg-white text-primary hover:bg-white/90 border-0 font-semibold shadow-sm" do %>
          Bắt đầu miễn phí →
        <% end %>
      </div>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Trường hợp sử dụng</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Tại sao phải nén ảnh?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["Trang web & blog",   "Ảnh lớn là nguyên nhân số 1 khiến trang tải chậm. Nén trước khi tải lên giúp giảm trọng lượng trang và cải thiện trải nghiệm người dùng trên tất cả các thiết bị."],
          ["Tệp đính kèm email",  "Hầu hết các ứng dụng email có giới hạn tệp đính kèm là 25 MB. Nén ảnh giúp dễ dàng gửi nhiều ảnh mà không gặp phải giới hạn kích thước."],
          ["Mạng xã hội",       "Các nền tảng như Instagram và Facebook nén lại ảnh bạn tải lên, thường làm giảm chất lượng. Nén trước để duy trì quyền kiểm soát tốt hơn về cách ảnh của bạn hiển thị."],
          ["Lưu trữ & sao lưu",   "Lưu trữ các bộ sưu tập ảnh lớn? Nén ảnh có thể giảm đáng kể yêu cầu lưu trữ mà không làm giảm chất lượng đáng kể ở kích thước xem thông thường."],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Câu hỏi thường gặp</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Các câu hỏi thường gặp</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["Nén ảnh có làm giảm chất lượng của nó không?",
           "Điều đó phụ thuộc vào mức độ nén. Nén mất dữ liệu (lossy compression) (JPEG, WebP) loại bỏ một số dữ liệu hình ảnh — ở cài đặt vừa phải, sự khác biệt hầu như không thể nhìn thấy bằng mắt thường. Sử dụng thanh trượt chất lượng để xem trước kết quả trước khi tải xuống."],
          ["Làm cách nào để nén ảnh xuống dưới 100 KB?",
           "Tải ảnh của bạn lên, đặt thanh trượt chất lượng khoảng 40–60% và kiểm tra
