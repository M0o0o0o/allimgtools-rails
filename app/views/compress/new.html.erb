<% content_for :title, "Free Image Compressor — Reduce File Size Online | Allimgtools" %>
<% content_for :description, "Compress JPEG, PNG, WebP, GIF, and AVIF images online for free. Adjust quality settings and reduce file size without losing detail. No signup required." %>
<% content_for :head do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Image Compressor",
    "url": "https://allimgtools.com/compress",
    "applicationCategory": "MultimediaApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": "Compress JPEG, PNG, WebP, GIF, and AVIF images online for free."
  }
  </script>
<% end %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Image Compress</h1>
    <p class="text-base-content/60 mt-2">Upload images to reduce file size by adjusting quality and format.</p>
  </div>

  <div class="card bg-base-100 shadow-sm">
    <div class="card-body">
      <%= render "shared/upload_form", success_path: "/compress", task: @task %>
    </div>
  </div>
</div>
