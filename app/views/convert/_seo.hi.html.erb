<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        ऑनलाइन इमेज कन्वर्ट करें —<br class="hidden sm:block"> मुफ्त फॉर्मेट कनवर्टर
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        अपनी इमेज को तुरंत एक फॉर्मेट से दूसरे में बदलें — किसी सॉफ्टवेयर या साइन-अप की आवश्यकता नहीं है। हमारा मुफ्त ऑनलाइन इमेज कनवर्टर JPEG, PNG, WebP, GIF और AVIF को सपोर्ट करता है। तेज़ वेबसाइटों के लिए WebP पर स्विच करें, छोटी फ़ाइलों के लिए PNG को JPEG में बदलें, या इमेज को ठीक उसी फॉर्मेट में तैयार करें जिसकी किसी प्लेटफॉर्म को आवश्यकता है। अपनी इमेज अपलोड करें और कुछ ही सेकंड में परिवर्तित फ़ाइल डाउनलोड करें।
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/convert_hero.png", alt: "ऑनलाइन इमेज फॉर्मेट कनवर्टर — JPEG, PNG, WebP, GIF और AVIF को तुरंत कन्वर्ट करें", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">चरण-दर-चरण</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ऑनलाइन इमेज कैसे कन्वर्ट करें</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">अपनी इमेज अपलोड करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">अपने डिवाइस से JPEG, PNG, WebP, GIF, या AVIF फ़ाइल को ड्रैग और ड्रॉप करें या चुनने के लिए क्लिक करें।</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">आउटपुट फॉर्मेट चुनें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">अपना लक्ष्य फॉर्मेट चुनें — JPEG, PNG, WebP, GIF, या AVIF। कनवर्टर सभी तकनीकी विवरणों को स्वचालित रूप से संभालता है।</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">अपनी परिवर्तित इमेज डाउनलोड करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">डाउनलोड पर क्लिक करें और अपनी परिवर्तित फ़ाइल को तुरंत सहेजें, कहीं भी उपयोग करने के लिए तैयार।</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        कोई खाता आवश्यक नहीं है। आपकी फ़ाइलें हमारे सर्वर पर कभी संग्रहीत नहीं होती हैं।
      </p>
    </div>

    <%# ── Format comparison table ────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">संदर्भ</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">JPEG, PNG, WebP, GIF और AVIF — कौन सा फॉर्मेट सही है?</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        हर इमेज फॉर्मेट की अपनी अलग खासियत होती है। अपनी ज़रूरतों के लिए सही आउटपुट फॉर्मेट चुनने के लिए इस तालिका का उपयोग करें:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">फॉर्मेट</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">इसके लिए सबसे अच्छा</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["JPEG",  "तस्वीरें, वेब इमेज, सोशल मीडिया — बेहतरीन संगतता, प्राकृतिक दृश्यों के लिए छोटी फ़ाइलें"],
              ["PNG",   "लोगो, इलस्ट्रेशन, स्क्रीनशॉट — पूर्ण पारदर्शिता समर्थन के साथ दोषरहित गुणवत्ता"],
              ["WebP",  "आधुनिक वेब — सर्वोत्तम समग्र संपीड़न; समान गुणवत्ता पर JPEG से छोटा, पारदर्शिता का समर्थन करता है"],
              ["GIF",   "सरल एनिमेशन, सीमित रंगों वाले ग्राफिक्स — एनिमेटेड सामग्री के लिए व्यापक प्लेटफॉर्म समर्थन"],
              ["AVIF",  "नेक्स्ट-जेन वेब — उत्कृष्ट गुणवत्ता के साथ उच्चतम संपीड़न दक्षता; प्रदर्शन-महत्वपूर्ण साइटों के लिए आदर्श"],
            ].each do |fmt, desc| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= fmt %></td>
                <td class="text-sm text-base-content/60"><%= desc %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">जब संदेह हो, तो वेब उपयोग के लिए WebP में या पारदर्शिता और दोषरहित गुणवत्ता की आवश्यकता होने पर PNG में कन्वर्ट करें।</p>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">उपयोग के मामले</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">इमेज फॉर्मेट क्यों कन्वर्ट करें?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["वेब के लिए WebP में कन्वर्ट करें",           "WebP फ़ाइलें समान गुणवत्ता पर JPEG से 25-35% छोटी होती हैं। अपनी साइट की इमेज को WebP में बदलना पेज स्पीड और कोर वेब वाइटल्स स्कोर के लिए सबसे तेज़ जीत में से एक है।"],
          ["छोटी फ़ाइलों के लिए PNG को JPEG में",         "PNG फ़ाइलें दोषरहित और बड़ी होती हैं। यदि आपकी इमेज को पारदर्शिता की आवश्यकता नहीं है, तो JPEG या WebP में बदलने से फ़ाइल का आकार नाटकीय रूप से कम हो जाता है — अक्सर 60-80% तक।"],
          ["गुणवत्ता और पारदर्शिता के लिए JPEG को PNG में", "एक पारदर्शी पृष्ठभूमि जोड़ने या ऐसी इमेज के साथ काम करने की आवश्यकता है जिसमें पिक्सेल-परफेक्ट निष्ठा की आवश्यकता हो? दोषरहित गुणवत्ता और अल्फा चैनल समर्थन प्राप्त करने के लिए PNG में कन्वर्ट करें।"],
          ["प्लेटफॉर्म-आवश्यक फॉर्मेट",             "विभिन्न उपकरण, CMS प्लेटफॉर्म और डिज़ाइन वर्कफ़्लो को विशिष्ट फ़ाइल फॉर्मेट की आवश्यकता होती है। यहां एक बार कन्वर्ट करें और हर बार सही फॉर्मेट अपलोड करें।"],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title.html_safe %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Web performance section ────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">वेब प्रदर्शन</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">तेज़ वेबसाइटों के लिए इमेज को WebP में कन्वर्ट करें</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Google के PageSpeed Insights और Lighthouse ऑडिट नियमित रूप से "नेक्स्ट-जेन फॉर्मेट में इमेज परोसें" को एक प्रमुख अनुकूलन के रूप में चिह्नित करते हैं। अपनी इमेज को अपलोड करने से पहले WebP या AVIF में बदलने से आपको मदद मिलती है:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["कोर वेब वाइटल्स में सुधार करें",        "छोटी इमेज फ़ाइलें LCP (लार्जेस्ट कंटेंटफुल पेंट) को कम करती हैं, जो Google के प्राथमिक रैंकिंग संकेतों में से एक है।"],
          ["बैंडविड्थ और होस्टिंग लागत कम करें", "आधुनिक फॉर्मेट फ़ाइल आकार के एक अंश पर समान दृश्य गुणवत्ता प्रदान करते हैं, जिससे सर्वर लोड और डेटा ट्रांसफर कम होता है।"],
          ["लाइटहाउस ऑडिट पास करें",          "पुरानी JPEG और PNG फ़ाइलों को WebP या AVIF में बदलने से PageSpeed Insights की सबसे आम चेतावनियों में से एक सीधे हल हो जाती है।"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200">
        <strong class="text-base-content font-semibold">वर्डप्रेस टिप:</strong> मीडिया लाइब्रेरी में अपलोड करने से पहले अपनी इमेज को यहां WebP में कन्वर्ट करें। यह प्लगइन निर्भरता से बचाता है और आपको आउटपुट गुणवत्ता और फॉर्मेट पर पूर्ण नियंत्रण देता है।
      </div>
    </div>

    <%# ── Bulk conversion ───────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">प्रो फीचर</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">बल्क इमेज कन्वर्जन</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        एक साथ कई इमेज कन्वर्ट करने की आवश्यकता है? हमारा बल्क कन्वर्जन टूल आपको एक ही बार में कई फ़ाइलें अपलोड और प्रोसेस करने देता है — इसके लिए एकदम सही:
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["ई-कॉमर्स",    "अपने स्टोर पर प्रकाशित करने से पहले पूरी उत्पाद इमेज लाइब्रेरी को WebP में कन्वर्ट करें।"],
          ["ब्लॉग और सामग्री", "फीचर्ड इमेज और इनलाइन फ़ोटो को एक ही बार में एक सुसंगत फॉर्मेट में बैच-कन्वर्ट करें।"],
          ["डिज़ाइन एक्सपोर्ट", "डिलीवरी या वेब प्रकाशन के लिए PNG डिज़ाइन एसेट के एक फ़ोल्डर को JPEG या WebP में कन्वर्ट करें।"],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= label.html_safe %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-6 flex items-center justify-between gap-6">
        <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 pointer-events-none"></div>
        <div class="absolute right-8 bottom-0 h-14 w-14 rounded-full bg-white/5 pointer-events-none"></div>
        <div class="relative">
          <p class="font-bold text-white mb-0.5">बल्क कन्वर्जन प्रो पर उपलब्ध है</p>
          <p class="text-white/60 text-sm">एक क्लिक में कई इमेज को किसी भी फॉर्मेट में कन्वर्ट करें।</p>
        </div>
        <%= link_to pricing_path, class: "relative shrink-0 btn btn-sm bg-white text-primary hover:bg-white/90 border-0 font-semibold shadow-sm" do %>
          मुफ्त में शुरू करें →
        <% end %>
      </div>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">अक्सर पूछे जाने वाले प्रश्न</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">अक्सर पूछे जाने वाले प्रश्न</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["लॉसी और लॉसलेस कन्वर्जन में क्या अंतर है?",
           "लॉसी कन्वर्जन (जैसे PNG को JPEG या WebP में बदलना) इमेज को कुछ डेटा को स्थायी रूप से हटाकर कंप्रेस करता है, जिसके परिणामस्वरूप मामूली गुणवत्ता समझौता के साथ छोटी फ़ाइलें बनती हैं। लॉसलेस कन्वर्जन (जैसे JPEG को PNG में) सभी पिक्सेल डेटा को बरकरार रखता है लेकिन फ़ाइल का आकार कम नहीं कर सकता है। वेब के लिए निर्धारित फ़ोटो के लिए, WebP जैसे लॉसी फॉर्मेट सर्वोत्तम आकार-से-गुणवत्ता संतुलन प्रदान करते हैं।"],
          ["क्या WebP सभी ब्राउज़रों द्वारा समर्थित है?",
           "हाँ। WebP सभी प्रमुख आधुनिक ब्राउज़रों — Chrome, Firefox, Safari, Edge और Opera — द्वारा पूरी तरह से समर्थित है, जो वैश्विक वेब उपयोगकर्ताओं के 97% से अधिक को कवर करता है। यह अब वेब इमेज के लिए अनुशंसित फॉर्मेट है और अधिकांश परियोजनाओं के लिए फॉलबैक के बिना उपयोग करना सुरक्षित है।"],
          ["PNG को JPEG में बदलने पर पारदर्शिता का क्या होता है?",
