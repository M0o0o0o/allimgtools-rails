<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        แปลงรูปภาพออนไลน์ —<br class="hidden sm:block"> ตัวแปลงรูปแบบฟรี
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        แปลงรูปภาพของคุณระหว่างรูปแบบได้ทันที — ไม่ต้องใช้ซอฟต์แวร์ ไม่ต้องลงทะเบียน ตัวแปลงรูปภาพออนไลน์ฟรีของเรารองรับ JPEG, PNG, WebP, GIF และ AVIF เปลี่ยนไปใช้ WebP เพื่อเว็บไซต์ที่เร็วขึ้น แปลง PNG เป็น JPEG เพื่อไฟล์ที่เล็กลง หรือเตรียมรูปภาพในรูปแบบที่แพลตฟอร์มต้องการ อัปโหลดรูปภาพของคุณและดาวน์โหลดไฟล์ที่แปลงแล้วได้ในไม่กี่วินาที
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/convert_hero.png", alt: "ตัวแปลงรูปแบบรูปภาพออนไลน์ — แปลง JPEG, PNG, WebP, GIF และ AVIF ได้ทันที", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ทีละขั้นตอน</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">วิธีแปลงรูปภาพออนไลน์</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">อัปโหลดรูปภาพของคุณ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">ลากและวาง หรือคลิกเพื่อเลือกไฟล์ JPEG, PNG, WebP, GIF หรือ AVIF จากอุปกรณ์ของคุณ</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">เลือกรูปแบบผลลัพธ์</p>
            <p class="text-sm text-base-content/55 leading-relaxed">เลือกรูปแบบเป้าหมายของคุณ — JPEG, PNG, WebP, GIF หรือ AVIF ตัวแปลงจะจัดการรายละเอียดทางเทคนิคทั้งหมดโดยอัตโนมัติ</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">ดาวน์โหลดรูปภาพที่แปลงแล้วของคุณ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">คลิกดาวน์โหลดและบันทึกไฟล์ที่แปลงแล้วของคุณได้ทันที พร้อมใช้งานได้ทุกที่</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        ไม่ต้องมีบัญชี ไฟล์ของคุณจะไม่ถูกเก็บไว้บนเซิร์ฟเวอร์ของเรา
      </p>
    </div>

    <%# ── Format comparison table ────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ข้อมูลอ้างอิง</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">JPEG, PNG, WebP, GIF &amp; AVIF — รูปแบบไหนที่เหมาะสม?</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        รูปแบบรูปภาพแต่ละรูปแบบมีจุดแข็งที่แตกต่างกัน ใช้ตารางนี้เพื่อเลือกรูปแบบผลลัพธ์ที่เหมาะสมกับความต้องการของคุณ:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">รูปแบบ</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">เหมาะสำหรับ</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["JPEG",  "ภาพถ่าย, รูปภาพบนเว็บ, โซเชียลมีเดีย — เข้ากันได้ดี, ขนาดไฟล์เล็กสำหรับภาพธรรมชาติ"],
              ["PNG",   "โลโก้, ภาพประกอบ, ภาพหน้าจอ — คุณภาพไม่สูญเสียพร้อมรองรับความโปร่งใสเต็มรูปแบบ"],
              ["WebP",  "เว็บสมัยใหม่ — การบีบอัดโดยรวมดีที่สุด; เล็กกว่า JPEG ที่คุณภาพเท่ากัน, รองรับความโปร่งใส"],
              ["GIF",   "แอนิเมชันง่ายๆ, กราฟิกที่มีสีจำกัด — รองรับแพลตฟอร์มกว้างขวางสำหรับเนื้อหาแอนิเมชัน"],
              ["AVIF",  "เว็บยุคใหม่ — ประสิทธิภาพการบีบอัดสูงสุดพร้อมคุณภาพยอดเยี่ยม; เหมาะสำหรับเว็บไซต์ที่เน้นประสิทธิภาพ"],
            ].each do |fmt, desc| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= fmt %></td>
                <td class="text-sm text-base-content/60"><%= desc %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">หากไม่แน่ใจ ให้แปลงเป็น WebP สำหรับการใช้งานบนเว็บ หรือ PNG เมื่อคุณต้องการความโปร่งใสและคุณภาพที่ไม่สูญเสีย</p>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">กรณีการใช้งาน</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ทำไมต้องแปลงรูปแบบรูปภาพ?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["แปลงเป็น WebP สำหรับเว็บ",           "ไฟล์ WebP มีขนาดเล็กกว่า JPEG 25–35% ที่คุณภาพเทียบเท่า การเปลี่ยนรูปภาพในเว็บไซต์ของคุณเป็น WebP เป็นหนึ่งในวิธีที่เร็วที่สุดในการเพิ่มความเร็วหน้าเว็บและคะแนน Core Web Vitals"],
          ["PNG เป็น JPEG เพื่อไฟล์ที่เล็กลง",         "ไฟล์ PNG เป็นแบบไม่สูญเสียและมีขนาดใหญ่ หากรูปภาพของคุณไม่ต้องการความโปร่งใส การแปลงเป็น JPEG หรือ WebP จะช่วยลดขนาดไฟล์ได้อย่างมาก — บ่อยครั้งถึง 60–80%"],
          ["JPEG เป็น PNG เพื่อคุณภาพ &amp; ความโปร่งใส", "ต้องการเพิ่มพื้นหลังโปร่งใส หรือทำงานกับรูปภาพที่ต้องการความแม่นยำระดับพิกเซล? แปลงเป็น PNG เพื่อให้ได้คุณภาพที่ไม่สูญเสียและรองรับช่องอัลฟ่า"],
          ["รูปแบบที่แพลตฟอร์มต้องการ",             "เครื่องมือ แพลตฟอร์ม CMS และเวิร์กโฟลว์การออกแบบที่แตกต่างกันต้องการรูปแบบไฟล์เฉพาะ แปลงที่นี่ครั้งเดียวและอัปโหลดรูปแบบที่ถูกต้องได้ทุกครั้ง"],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title.html_safe %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Web performance section ────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ประสิทธิภาพของเว็บ</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">แปลงรูปภาพเป็น WebP เพื่อเว็บไซต์ที่เร็วขึ้น</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        PageSpeed Insights และ Lighthouse ของ Google มักจะระบุ "การให้บริการรูปภาพในรูปแบบยุคใหม่" เป็นการเพิ่มประสิทธิภาพที่สำคัญ การแปลงรูปภาพของคุณเป็น WebP หรือ AVIF ก่อนอัปโหลดจะช่วยให้คุณ:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["ปรับปรุง Core Web Vitals",        "ไฟล์รูปภาพที่เล็กลงช่วยลด LCP (Largest Contentful Paint) ซึ่งเป็นหนึ่งในสัญญาณการจัดอันดับหลักของ Google"],
          ["ลดแบนด์วิดท์และค่าใช้จ่ายโฮสติ้ง", "รูปแบบที่ทันสมัยให้คุณภาพการมองเห็นเท่าเดิมแต่มีขนาดไฟล์เพียงเล็กน้อย ซึ่งช่วยลดภาระเซิร์ฟเวอร์และการถ่ายโอนข้อมูล"],
          ["ผ่านการตรวจสอบ Lighthouse",          "การแปลงไฟล์ JPEG และ PNG แบบเก่าเป็น WebP หรือ AVIF จะช่วยแก้ไขคำเตือน PageSpeed Insights ที่พบบ่อยที่สุดโดยตรง"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200">
        <strong class="text-base-content font-semibold">เคล็ดลับ WordPress:</strong> แปลงรูปภาพของคุณเป็น WebP ที่นี่ก่อนอัปโหลดไปยังคลังสื่อ สิ่งนี้จะช่วยหลีกเลี่ยงการพึ่งพาปลั๊กอินและให้คุณควบคุมคุณภาพและรูปแบบผลลัพธ์ได้อย่างเต็มที่
      </div>
    </div>

    <%# ── Bulk conversion ───────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">คุณสมบัติระดับโปร</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">การแปลงรูปภาพจำนวนมาก</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        ต้องการแปลงรูปภาพหลายรูปพร้อมกันหรือไม่? เครื่องมือแปลงจำนวนมากของเราช่วยให้คุณอัปโหลดและประมวลผลไฟล์หลายไฟล์ได้ในครั้งเดียว — เหมาะสำหรับ:
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["อีคอมเมิร์ซ",    "แปลงคลังรูปภาพผลิตภัณฑ์ทั้งหมดเป็น WebP ก่อนเผยแพร่ไปยังร้านค้าของคุณ"],
          ["บล็อก &amp; เนื้อหา", "แปลงรูปภาพเด่นและรูปภาพแทรกเป็นรูปแบบที่สอดคล้องกันในครั้งเดียว"],
          ["การส่งออกงานออกแบบ", "แปลงโฟลเดอร์ของไฟล์ PNG สำหรับงานออกแบบเป็น JPEG หรือ WebP สำหรับการส่งมอบหรือเผยแพร่บนเว็บ"],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= label.html_safe %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-6 flex items-center justify-between gap-6">
        <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 pointer-events-none"></div>
        <div class="absolute right-8 bottom-0 h-14 w-14 rounded-full bg-white/5 pointer-events-none"></div>
        <div class="relative">
          <p class="font-bold text-white mb-0.5">การแปลงจำนวนมากมีให้ใช้งานในแผน Pro</p>
          <p class="text-white/60 text-sm">แปลงรูปภาพหลายรูปเป็นรูปแบบใดก็ได้ในคลิกเดียว</p>
        </div>
        <%= link_to pricing_path, class: "relative shrink-0 btn btn-sm bg-white text-primary hover:bg-white/90 border-0 font-semibold shadow-sm" do %>
          เริ่มฟรี →
        <% end %>
      </div>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">คำถามที่พบบ่อย</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">คำถามที่พบบ่อย</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["การแปลงแบบ Lossy และ Lossless แตกต่างกันอย่างไร?",
           "การแปลงแบบ Lossy (เช่น การแปลง PNG เป็น JPEG หรือ WebP) จะบีบอัดรูปภาพโดยการลบข้อมูลบางส่วนออกอย่างถาวร ทำให้ได้ไฟล์ที่มีขนาดเล็กลงโดยมีการแลกเปลี่ยนคุณภาพเล็กน้อย การแปลงแบบ Lossless (เช่น JPEG เป็น PNG) จะเก็บข้อมูลพิกเซลทั้งหมดไว้ แต่อาจไม่ลดขนาดไฟล์ สำหรับรูปภาพที่ใช้บนเว็บ รูปแบบ Lossy เช่น WebP ให้ความสมดุลระหว่างขนาดและคุณภาพที่ดีที่สุด"],
          ["WebP รองรับโดยเบราว์เซอร์ทั้งหมดหรือไม่?",
           "ใช่ WebP ได้รับการสนับสนุนอย่างเต็มที่จากเบราว์เซอร์สมัยใหม่ที่สำคัญทั้งหมด — Chrome, Firefox, Safari, Edge และ Opera — ครอบคลุมผู้ใช้เว็บทั่วโลกกว่า 97% ปัจจุบันเป็นรูปแบบที่แนะนำสำหรับรูปภาพบนเว็บและปลอดภัยที่จะใช้โดยไม่ต้องมี Fallback สำหรับโครงการส่วนใหญ่"],
          ["เกิดอะไรขึ้นกับความโปร่งใสเมื่อ
