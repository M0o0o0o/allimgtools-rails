<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        線上裁切圖片 —<br class="hidden sm:block"> 免費、精準、即時
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        在幾秒鐘內修剪、重新構圖和裁切您的圖片 — 無需軟體，無需註冊。我們的免費線上圖片裁切工具支援 JPEG、PNG、WebP、GIF 和 AVIF 檔案。選擇自由裁切或鎖定標準長寬比 — 1:1 用於個人資料圖片，16:9 用於 YouTube 縮圖，9:16 用於限時動態等。立即移除不需要的邊框，聚焦主題，並為任何平台準備您的圖片。
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/crop_hero.png", alt: "線上圖片裁切工具 — 自由裁切或固定長寬比裁切 JPEG、PNG、WebP", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">逐步教學</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">如何線上裁切圖片</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">上傳您的圖片</p>
            <p class="text-sm text-base-content/55 leading-relaxed">從您的裝置拖放或點擊選擇 JPEG、PNG、WebP、GIF 或 AVIF 檔案。</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">選擇裁切區域</p>
            <p class="text-sm text-base-content/55 leading-relaxed">拖曳裁切手柄自由定義您的區域，或選擇預設比例 — 1:1、4:3、16:9、3:2 或 9:16 — 以鎖定比例。</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">下載您裁切後的圖片</p>
            <p class="text-sm text-base-content/55 leading-relaxed">點擊下載並立即以原始格式儲存您裁切後的檔案。</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        無需帳戶。您的檔案絕不會儲存在我們的伺服器上。
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">支援格式</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">裁切 JPEG、PNG、WebP 及更多</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "最常見的圖片格式。裁切清晰，同時保留自然色彩和漸變。" },
          { name: "PNG",        desc: "支援透明度。裁切保留 Alpha 色版，使透明區域保持完整。" },
          { name: "WebP",       desc: "Google 的現代格式。裁切時保持完整保真度 — 非常適合網路優化圖片。" },
          { name: "GIF",        desc: "裁切靜態 GIF，不影響調色板或透明度。" },
          { name: "AVIF",       desc: "具有卓越品質的下一代格式。裁切並保留所有細節。" },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Aspect ratio reference table ───────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">參考</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">您應該使用哪種長寬比？</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        不同的平台和使用情境需要不同的比例。選擇正確的比例，您的圖片每次都會看起來完美構圖：
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">比例</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">最佳用途</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["1:1",  "Instagram 貼文、個人資料圖片、頭像、應用程式圖示"],
              ["16:9", "YouTube 縮圖、寬螢幕影片封面、部落格標題圖"],
              ["4:3",  "標準攝影、簡報、經典照片列印"],
              ["9:16", "Instagram 限時動態、TikTok 影片、Reels、Shorts 封面"],
              ["3:2",  "單眼相機標準、風景攝影、印刷相簿"],
            ].each do |ratio, uses| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= ratio %></td>
                <td class="text-sm text-base-content/60"><%= uses %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">您也可以自由裁切，不鎖定任何比例 — 只需拖曳到您想要的確切區域。</p>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">使用情境</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">為何要裁切您的圖片？</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["個人資料圖片",         "鎖定 1:1 比例，將任何照片裁切成完美的正方形，適用於 LinkedIn、Twitter、GitHub 或任何顯示圓形或方形頭像的平台。"],
          ["縮圖&amp;封面",  "為 YouTube 縮圖、部落格標題圖或社群媒體預覽卡片，框選圖片中最引人注目的部分。"],
          ["移除不需要的區域",    "消除分散注意力的背景、邊框、浮水印或空白區域 — 只保留重要的部分。"],
          ["適用於平台的圖片",    "每個平台都有其偏好的尺寸。在上傳前裁切到正確的比例，這樣您的圖片就不會被尷尬地自動裁切。"],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title.html_safe %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Tips ──────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">提示</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">裁切時獲得最佳效果</h2>
      </div>
      <ul class="space-y-4 mb-4">
        <% [
          ["從高解析度原始圖片開始", "裁切會減少您保留的像素區域。高解析度來源為您提供更多操作空間，並確保裁切後的結果保持清晰。"],
          ["為平台使用長寬比鎖定",   "為特定平台準備圖片時，請務必先鎖定比例。這能確保結果符合所需尺寸，無需猜測。"],
          ["壓縮前先裁切",               "先裁切，然後再壓縮。移除不需要的像素可減少您需要壓縮的檔案大小 — 在相同的輸出尺寸下提供更好的品質。"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">常見問題</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">常見問題</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["我可以裁切到特定的像素尺寸嗎？",
           "是的。使用自由裁切模式並拖曳手柄以選擇您想要的區域。裁切工具會在您拖曳時顯示當前的像素尺寸，因此您可以達到精確的尺寸。對於固定比例（例如 Instagram 的 1080×1080），請鎖定 1:1 比例，並在裁切後根據需要調整大小。"],
          ["裁切會降低圖片品質嗎？",
           "不會 — 裁切是對保留像素的非破壞性操作。它只是移除您選擇範圍之外的區域，而不會改變您保留部分的像素資料。儲存的檔案在裁切區域內是完整品質的。"],
          ["裁切和調整大小有什麼區別？",
           "裁切是移除圖片的一部分 — 它改變了畫布區域並減少了總像素數，而沒有縮放。調整大小是將整個圖片放大或縮小，改變尺寸但保留所有內容。使用裁切來重新構圖；使用調整大小來改變輸出尺寸。"],
          ["長寬比是什麼意思？",
           "長寬比是圖片寬度與高度之間的比例關係，表示為兩個數字，中間用冒號分隔（例如 16:9）。它描述了圖片的形狀。16:9 的圖片比其高度更寬；1:1 的圖片是完美的正方形。在裁切時鎖定長寬比可確保您調整裁切區域時比例保持固定。"],
          ["支援哪些格式？",
           "您可以裁切 JPEG、JPG、PNG、WebP、GIF 和 AVIF 檔案。輸出會以與原始檔案相同的格式儲存，保留透明度 (PNG) 和其他特定格式的功能。"],
          ["我可以裁切 PNG 並保留其透明背景嗎？",
           "是的。當您裁切 PNG 時，裁切選區外的透明區域會被移除，但裁切區域內的透明度會完全保留。下載的檔案將保留 Alpha 色版。"],
        ].each do |question, answer| %>
          <div class="collapse collapse-plus rounded-xl border border-base-200 bg-base-100 hover:border-primary/20 transition-colors">
            <input type="checkbox">
            <div class="collapse-title font-semibold text-base-content text-sm"><%= question %></div>
            <div class="collapse-content">
              <p class="text-sm text-base-content/60 leading-relaxed"><%= answer %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Footer note ─────────────────────────────────────────────────── %>
    <p class="text-xs text-base-content/25 text-right">最後更新：2026 年 5 月</p>

  </div>
</section>
