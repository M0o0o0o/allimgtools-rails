<% content_for :title, t("crop.page_title") %>
<% content_for :description, t("crop.page_description") %>
<% content_for :head do %>
  <style>
    cropper-canvas { display: block; width: 100%; height: 100%; }
  </style>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Image Cropper",
    "url": "https://allimgtools.com/crop",
    "applicationCategory": "MultimediaApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": "Crop images online for free."
  }
  </script>
<% end %>
<% content_for :main_class, "flex-1 flex flex-col min-h-0" %>

<div data-controller="crop-tool"
     data-crop-tool-task-id-value="<%= @task.task_id %>"
     data-crop-tool-start-url-value="<%= start_crop_path %>"
     class="flex-1 flex flex-col min-h-0 relative"
     data-action="dragenter->crop-tool#onDragEnter
                  dragover->crop-tool#onDragOver
                  dragleave->crop-tool#onDragLeave
                  drop->crop-tool#onDrop">

  <%# ─── Drag overlay ───────────────────────────────────────────── %>
  <div class="hidden absolute inset-0 z-20 m-3 border-2 border-dashed border-primary rounded-2xl
              bg-primary/5 flex items-center justify-center pointer-events-none"
       data-crop-tool-target="dragOverlay">
    <div class="text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-primary mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <p class="text-base font-semibold text-primary"><%= t("common.drop_image") %></p>
    </div>
  </div>

  <%# ─── Main layout ───────────────────────────────────────────── %>
  <div class="flex-1 flex min-h-0">

    <%# ─── Desktop sidebar ────── %>
    <aside class="hidden lg:flex flex-col w-72 bg-base-100 border-r border-base-200 p-6 shrink-0">

      <h2 class="text-base font-bold mb-6"><%= t("crop.sidebar_title") %></h2>

      <div class="flex-1 flex flex-col gap-6">
        <div>
          <p class="text-xs font-semibold text-base-content/40 uppercase tracking-wide mb-3"><%= t("crop.aspect_ratio") %></p>
          <div class="flex flex-wrap gap-2">
            <button class="btn btn-primary btn-sm"
                    data-crop-tool-target="aspectBtn"
                    data-ratio="free"
                    data-action="click->crop-tool#setAspectRatio">
              <%= t("crop.free") %>
            </button>
            <button class="btn btn-outline btn-sm"
                    data-crop-tool-target="aspectBtn"
                    data-ratio="1:1"
                    data-action="click->crop-tool#setAspectRatio">
              1:1
            </button>
            <button class="btn btn-outline btn-sm"
                    data-crop-tool-target="aspectBtn"
                    data-ratio="16:9"
                    data-action="click->crop-tool#setAspectRatio">
              16:9
            </button>
            <button class="btn btn-outline btn-sm"
                    data-crop-tool-target="aspectBtn"
                    data-ratio="4:3"
                    data-action="click->crop-tool#setAspectRatio">
              4:3
            </button>
            <button class="btn btn-outline btn-sm"
                    data-crop-tool-target="aspectBtn"
                    data-ratio="3:2"
                    data-action="click->crop-tool#setAspectRatio">
              3:2
            </button>
          </div>
        </div>
      </div>

      <button class="btn btn-primary w-full mt-6 gap-2"
              data-crop-tool-target="startBtn"
              data-action="click->crop-tool#startCrop"
              disabled>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h4V3m14 14h-4v7M3 10l18 11M3 10L21 3"/>
        </svg>
        <%= t("crop.start") %>
      </button>
    </aside>

    <%# ─── Scrollable content ─────────────────────────────────────── %>
    <div class="flex-1 overflow-auto flex flex-col min-h-0">

      <%# Idle: dropzone %>
      <div class="flex flex-col min-h-full"
           data-crop-tool-target="dropzoneArea">
        <div class="flex-1 m-4 sm:m-6 border-2 border-dashed border-base-300 rounded-2xl cursor-pointer
                    flex flex-col items-center justify-center text-center
                    transition-colors hover:border-primary hover:bg-primary/5"
             data-action="click->crop-tool#openFilePicker">
          <div class="flex flex-col items-center gap-4 p-10 pointer-events-none">
            <h1 class="text-2xl font-bold"><%= t("crop.title") %></h1>
            <p class="text-sm text-base-content/60"><%= t("crop.description") %></p>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-base-content/25 mt-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h4V3m14 14h-4v7M3 10l18 11M3 10L21 3"/>
            </svg>
            <div>
              <p class="text-base font-semibold text-base-content"><%= t("common.drag_click_single") %></p>
              <p class="text-sm text-base-content/50 mt-1"><%= t("common.file_types_single") %></p>
            </div>
          </div>
        </div>
      </div>

      <%# Active: cropper %>
      <div class="hidden flex flex-col min-h-0 flex-1"
           data-crop-tool-target="contentArea">

        <div class="flex-1 p-4 sm:p-6 pb-28 lg:pb-6 flex flex-col gap-4 min-h-0">
          <div class="relative mx-auto w-fit">
            <img data-crop-tool-target="cropperImg"
                 src=""
                 alt="Preview"
                 class="block max-w-full">
          </div>
        </div>

        <%# Progress / status %>
        <div class="hidden px-4 pb-4 flex items-center justify-center gap-3" data-crop-tool-target="progressArea">
          <span class="loading loading-spinner loading-sm text-primary"></span>
          <span class="text-sm text-base-content/70" data-crop-tool-target="status"><%= t("common.processing") %></span>
        </div>

      </div>

    </div>
  </div>

  <%# ─── Fixed bottom-right: Settings (mobile) + Replace ──────────── %>
  <div class="hidden fixed bottom-6 right-6 z-10 flex flex-col items-end gap-2"
       data-crop-tool-target="fixedActions">
    <button class="btn btn-outline btn-sm gap-2 bg-base-100 shadow-lg lg:hidden"
            data-action="click->crop-tool#openSettings">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <%= t("common.settings") %>
    </button>
    <button class="btn btn-outline btn-sm gap-2 bg-base-100 shadow-lg"
            data-action="click->crop-tool#openFilePicker">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <%= t("common.replace") %>
    </button>
  </div>

  <%# ─── Fixed bottom-left: Start (mobile only) ───────────────────── %>
  <div class="hidden fixed bottom-6 left-6 z-10 lg:hidden"
       data-crop-tool-target="fixedActions">
    <button class="btn btn-primary gap-2 shadow-lg"
            data-crop-tool-target="startBtn"
            data-action="click->crop-tool#startCrop"
            disabled>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h4V3m14 14h-4v7M3 10l18 11M3 10L21 3"/>
      </svg>
      <%= t("crop.start") %>
    </button>
  </div>

  <%# Hidden file input %>
  <input type="file"
         accept="image/jpeg,image/png,image/gif,image/webp,image/avif"
         class="hidden"
         data-crop-tool-target="input"
         data-action="change->crop-tool#onFileChange">

  <%# ─── Mobile bottom sheet modal ──────────────────────────────── %>
  <dialog id="settings-modal" class="modal modal-bottom sm:modal-middle">
    <div class="modal-box rounded-t-2xl sm:rounded-2xl">
      <h3 class="font-bold text-lg mb-5"><%= t("crop.settings") %></h3>

      <div class="flex flex-col gap-5 mb-6">
        <div>
          <p class="text-sm font-medium mb-3"><%= t("crop.aspect_ratio") %></p>
          <div class="flex flex-wrap gap-2">
            <button class="btn btn-primary btn-sm"
                    data-crop-tool-target="aspectBtn"
                    data-ratio="free"
                    data-action="click->crop-tool#setAspectRatio">
              <%= t("crop.free") %>
            </button>
            <button class="btn btn-outline btn-sm"
                    data-crop-tool-target="aspectBtn"
                    data-ratio="1:1"
                    data-action="click->crop-tool#setAspectRatio">
              1:1
            </button>
            <button class="btn btn-outline btn-sm"
                    data-crop-tool-target="aspectBtn"
                    data-ratio="16:9"
                    data-action="click->crop-tool#setAspectRatio">
              16:9
            </button>
            <button class="btn btn-outline btn-sm"
                    data-crop-tool-target="aspectBtn"
                    data-ratio="4:3"
                    data-action="click->crop-tool#setAspectRatio">
              4:3
            </button>
            <button class="btn btn-outline btn-sm"
                    data-crop-tool-target="aspectBtn"
                    data-ratio="3:2"
                    data-action="click->crop-tool#setAspectRatio">
              3:2
            </button>
          </div>
        </div>
      </div>

      <button class="btn btn-primary w-full gap-2"
              data-crop-tool-target="startBtn"
              data-action="click->crop-tool#startCrop"
              disabled>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h4V3m14 14h-4v7M3 10l18 11M3 10L21 3"/>
        </svg>
        <%= t("crop.start") %>
      </button>

      <form method="dialog" class="mt-3">
        <button class="btn btn-ghost w-full"><%= t("common.close") %></button>
      </form>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

</div>
