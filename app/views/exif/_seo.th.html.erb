<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        ลบข้อมูล EXIF ออนไลน์ —<br class="hidden sm:block"> ปกป้องความเป็นส่วนตัวของคุณได้ทันที
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        ลบข้อมูลเมตา (metadata) ทั้งหมดออกจากรูปภาพของคุณได้ทันที — ไม่ต้องใช้ซอฟต์แวร์ ไม่ต้องลงทะเบียน โปรแกรมลบ EXIF ออนไลน์ฟรีของเราจะลบตำแหน่ง GPS, รุ่นกล้อง, วันที่ถ่าย, ข้อมูลเลนส์, การตั้งค่าการเปิดรับแสง และข้อมูลเมตา IPTC/XMP ทั้งหมดออกจากไฟล์ JPEG, PNG, WebP และ GIF อย่างถาวร ไม่ว่าคุณจะขายสินค้าออนไลน์, แชร์รูปภาพสาธารณะ หรือเตรียมรูปภาพสำหรับโซเชียลมีเดีย ข้อมูลส่วนตัวของคุณจะยังคงเป็นส่วนตัว
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/exif_hero.png", alt: "โปรแกรมลบ EXIF ออนไลน์ — ลบ GPS, ข้อมูลกล้อง และข้อมูลเมตาออกจากรูปภาพเพื่อปกป้องความเป็นส่วนตัว", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ทีละขั้นตอน</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">วิธีลบข้อมูล EXIF ออนไลน์</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">อัปโหลดรูปภาพของคุณ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">ลากและวาง หรือคลิกเพื่อเลือกไฟล์ JPEG, PNG, WebP หรือ GIF คุณสามารถอัปโหลดรูปภาพหลายไฟล์พร้อมกันได้</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">ลบข้อมูลเมตาทั้งหมด</p>
            <p class="text-sm text-base-content/55 leading-relaxed">คลิกปุ่มลบ แล้วข้อมูลเมตา EXIF, IPTC และ XMP ทั้งหมดจะถูกลบออกจากรูปภาพของคุณทันที</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">ดาวน์โหลดรูปภาพที่สะอาดของคุณ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">ดาวน์โหลดรูปภาพที่ไม่มีข้อมูลเมตา เนื้อหาภาพของรูปภาพของคุณจะไม่เปลี่ยนแปลงเลย</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        ไม่ต้องมีบัญชี ไฟล์ของคุณจะไม่ถูกจัดเก็บไว้บนเซิร์ฟเวอร์ของเรา
      </p>
    </div>

    <%# ── What EXIF reveals ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">อ้างอิง</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ข้อมูล EXIF เปิดเผยอะไรเกี่ยวกับคุณบ้าง</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        รูปภาพทุกรูปที่ถ่ายด้วยสมาร์ทโฟนหรือกล้องดิจิทัลจะฝังข้อมูลเมตาที่ซ่อนอยู่ นี่คือสิ่งที่ข้อมูลเหล่านั้นสามารถเปิดเผยได้เมื่อคุณแชร์รูปภาพที่ยังไม่ได้ลบข้อมูล:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">ฟิลด์ EXIF</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">สิ่งที่เปิดเผย</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["ละติจูด / ลองจิจูด GPS", "ตำแหน่งที่ถ่ายรูปภาพอย่างแม่นยำ"],
              ["วันที่/เวลาต้นฉบับ",         "วันที่และเวลาที่ถ่ายภาพอย่างแม่นยำ"],
              ["ยี่ห้อ / รุ่น",             "ยี่ห้อและรุ่นกล้อง (เช่น Apple iPhone 15 Pro)"],
              ["ซอฟต์แวร์",                 "ซอฟต์แวร์แก้ไขที่ใช้ (เช่น Adobe Lightroom, Snapseed)"],
              ["ศิลปิน / ลิขสิทธิ์",       "ชื่อและตัวตนของช่างภาพ"],
              ["รุ่นเลนส์",                "เลนส์ที่ใช้ — บ่งบอกถึงอุปกรณ์ระดับมืออาชีพ"],
              ["เวลาเปิดรับแสง / ISO",       "การตั้งค่ากล้องที่สามารถระบุสไตล์การถ่ายภาพของคุณได้"],
            ].each do |field, reveals| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= field %></td>
                <td class="text-sm text-base-content/60"><%= reveals %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">ฟิลด์ทั้งหมดข้างต้น — และอื่นๆ — จะถูกลบออกเมื่อคุณใช้เครื่องมือนี้</p>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">กรณีการใช้งาน</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ทำไมต้องลบข้อมูล EXIF?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["ขายสินค้าออนไลน์",     "รูปภาพสินค้าที่ขายมักมีพิกัด GPS ของบ้านคุณ ลบข้อมูลเมตาก่อนโพสต์ลงในตลาดออนไลน์ เช่น eBay, Craigslist หรือ Facebook Marketplace"],
          ["แชร์รูปภาพสาธารณะ",  "กำลังอัปโหลดไปยังฟอรัม, Discord หรือแกลเลอรีสาธารณะใช่หรือไม่? รูปภาพของคุณอาจเผยแพร่ที่อยู่บ้านของคุณ ลบ EXIF ก่อนแชร์ไปยังที่ที่คุณไม่สามารถควบคุมได้"],
          ["การแชร์แบบมืออาชีพ",     "งานที่ส่งให้ลูกค้าไม่ควรรวมถึงอุปกรณ์กล้อง, วันที่ถ่าย หรือรายละเอียดส่วนตัวของคุณ ลบข้อมูลเมตาเพื่อการส่งมอบงานที่สะอาดและเป็นมืออาชีพ"],
          ["ความปลอดภัยบนโซเชียลมีเดีย",      "แม้ว่าแพลตฟอร์มส่วนใหญ่จะลบ EXIF เมื่ออัปโหลด แต่บางแพลตฟอร์มก็ไม่ลบ — และผู้ใช้บางคนก็ดาวน์โหลดไฟล์ต้นฉบับ ลบข้อมูลเมตาด้วยตัวเองก่อนอัปโหลดเพื่อให้แน่ใจ"],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── What's removed ────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ครอบคลุม</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ลบข้อมูลเมตาทั้งหมดได้ในคลิกเดียว</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        เครื่องมือนี้จะลบข้อมูลเมตาทุกชั้นที่ฝังอยู่ในรูปภาพของคุณ — ไม่ใช่แค่ EXIF พื้นฐานเท่านั้น แต่ยังรวมถึงข้อมูล IPTC และ XMP ที่ใช้ในเวิร์กโฟลว์ระดับมืออาชีพด้วย:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["ข้อมูล GPS และตำแหน่ง",        "ละติจูด, ลองจิจูด, ระดับความสูง และทิศทางแผนที่ — หายไปทั้งหมด"],
          ["ข้อมูลกล้องและเลนส์",         "ยี่ห้อ, รุ่น, รุ่นเลนส์, เวอร์ชันเฟิร์มแวร์ และหมายเลขซีเรียลถูกลบออกทั้งหมด"],
          ["การประทับวันที่และเวลา",         "DateTimeOriginal, DateTimeDigitized และการประทับเวลาที่เกี่ยวข้องทั้งหมดถูกลบออก"],
          ["การตั้งค่าการเปิดรับแสง",          "ISO, รูรับแสง, ความเร็วชัตเตอร์, สมดุลแสงขาว, โหมดแฟลช — ถูกล้างทั้งหมด"],
          ["ข้อมูลเมตา IPTC / XMP",        "ประกาศลิขสิทธิ์, คำหลัก, คำบรรยาย, ข้อมูลผู้สร้าง และข้อความสิทธิ์จากซอฟต์แวร์ระดับมืออาชีพ"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
    </div>

    <%# ── Bulk removal ───────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">คุณสมบัติ Pro</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">การลบ EXIF จำนวนมาก</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        ต้องการลบข้อมูลเมตาจากรูปภาพหลายสิบรูปพร้อมกันหรือไม่? การลบ EXIF แบบกลุ่มมีให้ใช้งานใน Pro — เหมาะสำหรับ:
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["ผู้ขายอีคอมเมิร์ซ",   "ทำความสะอาดชุดรูปภาพสินค้าทั้งหมดก่อนลงขายในตลาดใดๆ"],
          ["ช่างภาพ",        "ส่งแกลเลอรีให้ลูกค้าโดยไม่เปิดเผยอุปกรณ์หรือตารางการถ่ายภาพของคุณ"],
          ["ผู้สร้างเนื้อหา",     "ล้างข้อมูลเมตาจากรูปภาพทั้งหมดในโพสต์หรือแคมเปญในครั้งเดียว"],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= label %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-6 flex items-center justify-between gap-6">
        <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 pointer-events-none"></div>
        <div class="absolute right-8 bottom-0 h-14 w-14 rounded-full bg-white/5 pointer-events-none"></div>
        <div class="relative">
          <p class="font-bold text-white mb-0.5">การลบแบบกลุ่มมีให้ใช้งานใน Pro</p>
          <p class="text-white/60 text-sm">ลบข้อมูลเมตาจากหลายไฟล์ได้ในคลิกเดียว</p>
        </div>
        <%= link_to pricing_path, class: "relative shrink-0 btn btn-sm bg-white text-primary hover:bg-white/90 border-0 font-semibold shadow-sm" do %>
          เริ่มต้นฟรี →
        <% end %>
      </div>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">คำถามที่พบบ่อย</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">คำถามที่พบบ่อย</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["ข้อมูล EXIF คืออะไร?",
           "EXIF (Exchangeable Image File Format) คือข้อมูลเมตาที่ฝังอยู่ในรูปภาพโดยอัตโนมัติจากกล้องดิจิทัลและสมาร์ทโฟน มันบันทึกรายละเอียดทางเทคนิค เช่น การตั้งค่ากล้อง, ข้อมูลเลนส์, วันที่และเวลา และที่สำคัญที่สุดคือตำแหน่ง GPS ข้อมูลนี้ถูกซ่อนอยู่ในไฟล์รูปภาพและมองไม่เห็นเมื่อคุณดูรูปภาพตามปกติ"],
          ["การลบ EXIF เป็นการถาวรหรือไม่?",
           "ใช่ เมื่อลบแล้ว ข้อมูลเมตาจะหายไปจากไฟล์ที่คุณดาวน์โหลด ไฟล์ต้นฉบับบนอุปกรณ์ของคุณจะไม่ถูกแตะต้อง ดังนั้นคุณจึงสามารถกลับไปใช้ไฟล์นั้นได้เสมอ เครื่องมือของเราประ
