<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        在线移除 EXIF 数据 —<br class="hidden sm:block"> 立即保护您的隐私
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        立即从您的照片中删除所有元数据 — 无需软件，无需注册。我们免费的在线 EXIF 移除工具可永久删除 JPEG、PNG、WebP 和 GIF 文件中的 GPS 位置、相机型号、拍摄日期、镜头信息、曝光设置以及所有 IPTC/XMP 元数据。无论您是在线销售商品、公开分享照片，还是为社交媒体准备图片，您的个人信息都将受到保护。
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/exif_hero.png", alt: "在线 EXIF 移除工具 — 从照片中删除 GPS、相机信息和元数据以保护隐私", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">分步指南</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">如何在线移除 EXIF 数据</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">上传您的图片</p>
            <p class="text-sm text-base-content/55 leading-relaxed">拖放或点击选择 JPEG、PNG、WebP 或 GIF 文件。您可以一次上传多张图片。</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">移除所有元数据</p>
            <p class="text-sm text-base-content/55 leading-relaxed">点击移除按钮，所有 EXIF、IPTC 和 XMP 元数据将立即从您的图片中删除。</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">下载您的纯净图片</p>
            <p class="text-sm text-base-content/55 leading-relaxed">下载您不含元数据的图片。照片的视觉内容完全不变。</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        无需账户。您的文件绝不会存储在我们的服务器上。
      </p>
    </div>

    <%# ── What EXIF reveals ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">参考</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">EXIF 数据会泄露您的哪些信息</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        智能手机或数码相机拍摄的每张照片都嵌入了隐藏的元数据。当您分享未处理的图片时，这些数据可能会暴露以下信息：
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">EXIF 字段</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">它会泄露什么</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["GPS 纬度 / 经度", "照片拍摄的确切位置"],
              ["原始日期时间",         "照片拍摄的精确日期和时间"],
              ["品牌 / 型号",             "相机品牌和型号（例如 Apple iPhone 15 Pro）"],
              ["软件",                 "使用的编辑软件（例如 Adobe Lightroom, Snapseed）"],
              ["艺术家 / 版权",       "摄影师姓名和身份"],
              ["镜头型号",                "使用的镜头 — 暗示专业设备"],
              ["曝光时间 / ISO",       "可识别您拍摄风格的相机设置"],
            ].each do |field, reveals| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= field %></td>
                <td class="text-sm text-base-content/60"><%= reveals %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">使用此工具时，以上所有字段以及更多信息都将被移除。</p>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">使用场景</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">为什么要移除 EXIF 数据？</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["在线销售商品",     "待售商品的照片通常包含您家的 GPS 坐标。在发布到 eBay、Craigslist 或 Facebook Marketplace 等市场之前，请先删除元数据。"],
          ["公开分享照片",  "上传到论坛、Discord 或公共图库？您的照片可能会泄露您的家庭住址。在您无法控制的任何地方分享之前，请移除 EXIF。"],
          ["专业分享",     "客户交付物不应包含您的相机设备、拍摄日期或个人详细信息。删除元数据以实现干净、专业的交付。"],
          ["社交媒体安全",      "尽管大多数平台在上传时会删除 EXIF，但有些平台不会 — 并且有些用户会下载原始文件。在上传之前自行删除元数据是唯一能确保安全的方法。"],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── What's removed ────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">覆盖范围</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">一键移除所有元数据</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        此工具会移除图片中嵌入的每个元数据层 — 不仅是基本的 EXIF，还包括专业工作流程中使用的 IPTC 和 XMP 数据：
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["GPS 和位置数据",        "纬度、经度、海拔和地图方向 — 全部移除。"],
          ["相机和镜头信息",         "品牌、型号、镜头型号、固件版本和序列号完全删除。"],
          ["日期和时间戳",         "原始日期时间、数字化日期时间以及所有相关时间戳均已移除。"],
          ["曝光设置",          "ISO、光圈、快门速度、白平衡、闪光模式 — 全部清除。"],
          ["IPTC / XMP 元数据",        "版权声明、关键词、标题、创作者信息以及专业软件中的权利声明。"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
    </div>

    <%# ── Bulk removal ───────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">专业版功能</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">批量移除 EXIF</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        需要一次性从数十张照片中删除元数据？专业版提供批量 EXIF 移除功能 — 非常适合：
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["电商卖家",   "在任何市场上架之前，清理整个产品照片集。"],
          ["摄影师",        "交付客户图库，同时不暴露您的设备或拍摄日程。"],
          ["内容创作者",     "一次性清除帖子或活动中所有图片的元数据。"],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= label %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-6 flex items-center justify-between gap-6">
        <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 pointer-events-none"></div>
        <div class="absolute right-8 bottom-0 h-14 w-14 rounded-full bg-white/5 pointer-events-none"></div>
        <div class="relative">
          <p class="font-bold text-white mb-0.5">专业版提供批量移除功能</p>
          <p class="text-white/60 text-sm">一键从多个文件中删除元数据。</p>
        </div>
        <%= link_to pricing_path, class: "relative shrink-0 btn btn-sm bg-white text-primary hover:bg-white/90 border-0 font-semibold shadow-sm" do %>
          免费开始 →
        <% end %>
      </div>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">常见问题</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">常见问题解答</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["什么是 EXIF 数据？",
           "EXIF（可交换图像文件格式）是数码相机和智能手机自动嵌入照片中的元数据。它记录了相机设置、镜头信息、日期和时间等技术细节，以及 — 最关键的 — GPS 位置。这些数据隐藏在图像文件中，当您正常查看照片时是不可见的。"],
          ["EXIF 移除是永久性的吗？",
           "是的。一旦移除，元数据将从您下载的文件中消失。您设备上的原始文件不会被触及，因此您随时可以恢复它。我们的工具处理的是副本 — 您上传的文件绝不会存储在我们的服务器上。"],
          ["移除 EXIF 会改变图片吗？",
           "不会。您照片的视觉内容完全不变。移除元数据只会影响隐藏的数据层，而不会影响像素。您的图片在移除前后看起来会一模一样。"],
          ["实际移除了哪些数据？",
           "所有数据：GPS 坐标、相机品牌和型号、镜头信息、曝光设置（ISO、光圈、快门速度）、日期和时间戳、使用的软件、艺术家姓名、版权声明以及所有 IPTC/XMP 字段。基本上所有非像素数据都将被删除。"],
          ["为什么在在线分享前要移除 EXIF？",
           "即使您信任某个平台，其他用户也可以下载您的图片并使用免费工具提取完整的元数据。如果存在 GPS 数据，任何人都可以精确地确定您拍摄照片的位置 — 这可能会暴露您的住所、工作地点或日常行程。"],
          ["社交媒体会自动删除 EXIF 吗？",
           "大多数主流平台（Instagram、Facebook、Twitter/X）在上传时确实会删除 EXIF，但这种行为可能会在不通知的情况下改变，不适用于所有文件类型，并且如果有人在您通过平台分享之前下载了文件，也无法保护您。在上传之前自行删除元数据是唯一有保障的方法。"],
        ].each do |question, answer| %>
          <div class="collapse collapse-plus rounded-xl border border-base-200 bg-base-100 hover:border-primary/20 transition-colors">
            <input type="checkbox">
            <div class="collapse-title font-semibold text-base-content text-sm"><%= question %></div>
            <div class="collapse-content">
              <p class="text-sm text-base-content/60 leading-relaxed"><%= answer %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Footer note ─────────────────────────────────────────────────── %>
    <p class="text-xs text-base-content/25 text-right">最后更新：2026 年 5 月</p>

  </div>
</section>
