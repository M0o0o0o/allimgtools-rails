<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        تعديل بيانات EXIF الوصفية عبر الإنترنت —<br class="hidden sm:block"> محرر بيانات الصور المجاني
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        اعرض وعدّل البيانات الوصفية المخفية داخل صورك — لا يلزم برنامج ولا تسجيل. يتيح لك محرر EXIF المجاني عبر الإنترنت تغيير إحداثيات GPS، وتصحيح طوابع التاريخ والوقت، وإضافة معلومات حقوق النشر والمؤلف، وتحديث الكلمات المفتاحية، والمزيد. يعمل مع ملفات JPEG و PNG. مثالي للمصورين، والمساهمين في بنوك الصور، وأي شخص يحتاج إلى تحكم دقيق في بيانات صوره.
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/exif_edit_hero.png", alt: "محرر EXIF عبر الإنترنت — تعديل حقول GPS والتاريخ وحقوق النشر والبيانات الوصفية في ملفات JPEG و PNG", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">خطوة بخطوة</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">كيفية تعديل بيانات EXIF الوصفية عبر الإنترنت</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">حمّل صورتك</p>
            <p class="text-sm text-base-content/55 leading-relaxed">اسحب وأفلت أو انقر لتحديد ملف JPEG أو PNG. يمكنك تحميل صور متعددة وتعديلها واحدة تلو الأخرى.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">عدّل حقول البيانات الوصفية</p>
            <p class="text-sm text-base-content/55 leading-relaxed">حدّث أي حقل EXIF — إحداثيات GPS، تاريخ الالتقاط، معلومات الكاميرا، حقوق النشر، اسم الفنان، الكلمات المفتاحية، أو الوصف. اترك الحقول فارغة لإزالتها.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">تطبيق وتنزيل</p>
            <p class="text-sm text-base-content/55 leading-relaxed">انقر على حفظ لتطبيق تغييراتك، ثم قم بتنزيل الصورة المحدثة. استخدم "تطبيق على جميع الصور" لنسخ نفس التعديلات على كل ملف قمت بتحميله.</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        لا يلزم حساب. ملفاتك لا تُخزّن على خوادمنا أبدًا.
      </p>
    </div>

    <%# ── Editable fields table ──────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">مرجع</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">حقول EXIF القابلة للتعديل</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        يمكن قراءة أو تعديل أو مسح كل حقل مدرج أدناه مباشرة في المحرر. تُكتب التغييرات مرة أخرى في ملف الصورة عند التنزيل — لا يتم المساس بالمحتوى المرئي لصورتك أبدًا.
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">حقل EXIF</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">ما يمكنك تعيينه</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["GPS Latitude / Longitude", "إضافة أو تغيير أو إزالة الموقع الذي التقطت فيه الصورة"],
              ["DateTimeOriginal",         "تصحيح تاريخ التقاط غير صحيح أو تعديل منطقة زمنية خاطئة"],
              ["Artist / Creator",         "أضف اسمك لتبقى حقوق التأليف معك في الملف"],
              ["Copyright",               "تضمين بيان حقوق النشر (مثال: © 2026 جين سميث)"],
              ["Keywords",                "أضف علامات قابلة للبحث لمكتبات الصور أو إدارة الأصول"],
              ["ImageDescription",        "اكتب تسمية توضيحية أو وصف نص بديل للصورة"],
              ["Make / Model",            "تحديث أو مسح حقول ماركة الكاميرا وطرازها"],
            ].each do |field, purpose| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= field %></td>
                <td class="text-sm text-base-content/60"><%= purpose %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">قد تكون حقول إضافية مرئية في وضع القراءة فقط اعتمادًا على البيانات المضمنة في الملف.</p>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">حالات الاستخدام</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">لماذا تعدّل بيانات EXIF الوصفية؟</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["إضافة حقوق النشر والاعتمادات",     "ضمّن اسمك، بيان حقوق النشر، وتفاصيل الاتصال مباشرة في الملف لتبقى معلومات الملكية مع الصورة أينما ذهبت."],
          ["تصحيح تاريخ أو وقت خاطئ",      "ساعات الكاميرا قد تنحرف، أو تتغير عبر المناطق الزمنية، أو تُعاد ضبطها بعد تبديل البطارية. صحّح تاريخ الالتقاط لتبقى مكتبة صورك مرتبة بدقة."],
          ["إضافة GPS للصور غير الموسومة",  "التقطت بكاميرا بدون GPS؟ أضف إحداثيات الموقع يدويًا لتظهر الصورة بشكل صحيح على الخرائط وفي عمليات البحث المستندة إلى الموقع."],
          ["تحضير صور بنوك الصور",     "تتطلب مكتبات الصور حقوق نشر دقيقة، وكلمات مفتاحية، وأوصافًا مضمنة في الملف. عدّل جميع الحقول المطلوبة قبل الإرسال لتسريع عملية المراجعة."],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Apply to all feature ───────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">التعديل المجمع</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">تطبيق التعديلات على صور متعددة</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        يعمل المحرر على صورة واحدة في كل مرة، ولكن يمكنك تحميل ملفات متعددة في جلسة واحدة. بعد تعديل الصورة الأولى، استخدم زر <strong class="text-base-content font-semibold">"تطبيق على جميع الصور"</strong> لنسخ تغييرات البيانات الوصفية الحالية إلى كل ملف آخر تم تحميله — مما يوفر عليك تكرار نفس التعديلات يدويًا.
      </p>
      <ul class="space-y-4">
        <% [
          ["حقوق نشر متسقة عبر جلسة تصوير",  "طبّق بيان حقوق النشر واسم الفنان الخاص بك على كل صورة من جلسة تصوير بنقرة واحدة."],
          ["كلمات مفتاحية مشتركة لمجموعة صور",       "عيّن نفس الكلمات المفتاحية الوصفية لجميع الصور المخصصة لمكتبة صور أو مجلد عميل."],
          ["وسم GPS موحد",                   "عيّن نفس الموقع لجميع الصور الملتقطة في نفس المكان أو الحدث."],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">الأسئلة الشائعة</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">الأسئلة المتكررة</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["ما هي بيانات EXIF التي يمكن تعديلها؟",
           "يمكنك تعديل إحداثيات GPS، التاريخ والوقت (DateTimeOriginal)، اسم الفنان/المنشئ، بيان حقوق النشر، الكلمات المفتاحية، وصف/تسمية الصورة، والشركة المصنعة/طراز الكاميرا. الحقول التي تتركها فارغة يتم مسحها من الملف. قد تُعرض حقول إضافية للقراءة فقط اعتمادًا على ما يحتويه الملف الأصلي."],
          ["هل يؤثر تعديل بيانات EXIF على جودة الصورة؟",
           "لا. تعديل EXIF يغير فقط طبقة البيانات الوصفية — بيانات البكسل التي تشكل صورتك لا تُمس أبدًا. ستبدو صورتك متطابقة قبل وبعد التعديل، ويبقى تنسيق الملف كما هو."],
          ["ما هي تنسيقات الملفات المدعومة؟",
           "يتم دعم JPEG و PNG بالكامل لقراءة وكتابة بيانات EXIF الوصفية. JPEG هو التنسيق الأكثر شيوعًا لبيانات EXIF ويدعم أوسع نطاق من الحقول. يدعم PNG مجموعة فرعية من حقول البيانات الوصفية. تنسيقات WebP و GIF لديها دعم محدود أو لا يوجد دعم لـ EXIF اعتمادًا على كيفية إنشائها."],
          ["كيف أضيف إحداثيات GPS إلى صورة؟",
           "افتح الصورة في المحرر، ابحث عن حقلي خط العرض وخط الطول لـ GPS، وأدخل الإحداثيات العشرية للموقع (مثال: 48
