<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        EXIF मेटाडेटा ऑनलाइन संपादित करें —<br class="hidden sm:block"> निःशुल्क इमेज डेटा एडिटर
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        अपनी छवियों के अंदर छिपे मेटाडेटा को देखें और संपादित करें — किसी सॉफ़्टवेयर या साइन-अप की आवश्यकता नहीं है। हमारा निःशुल्क ऑनलाइन EXIF एडिटर आपको GPS निर्देशांक बदलने, दिनांक और समय स्टैम्प ठीक करने, कॉपीराइट और लेखक की जानकारी जोड़ने, कीवर्ड अपडेट करने और बहुत कुछ करने की सुविधा देता है। JPEG और PNG फ़ाइलों के साथ काम करता है। फोटोग्राफरों, स्टॉक योगदानकर्ताओं और किसी भी व्यक्ति के लिए बिल्कुल सही है जिसे अपने इमेज डेटा पर सटीक नियंत्रण की आवश्यकता है।
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/exif_edit_hero.png", alt: "ऑनलाइन EXIF एडिटर — JPEG और PNG फ़ाइलों में GPS, दिनांक, कॉपीराइट और मेटाडेटा फ़ील्ड संपादित करें", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">चरण-दर-चरण</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">EXIF मेटाडेटा ऑनलाइन कैसे संपादित करें</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">अपनी इमेज अपलोड करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">JPEG या PNG फ़ाइल को ड्रैग और ड्रॉप करें या चुनने के लिए क्लिक करें। आप कई छवियां अपलोड कर सकते हैं और उन्हें एक-एक करके संपादित कर सकते हैं।</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">मेटाडेटा फ़ील्ड संपादित करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">किसी भी EXIF फ़ील्ड को अपडेट करें — GPS निर्देशांक, ली गई दिनांक, कैमरा जानकारी, कॉपीराइट, कलाकार का नाम, कीवर्ड या विवरण। उन्हें हटाने के लिए फ़ील्ड खाली छोड़ दें।</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">लागू करें और डाउनलोड करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">अपने परिवर्तनों को लिखने के लिए सहेजें पर क्लिक करें, फिर अपडेट की गई इमेज डाउनलोड करें। आपके द्वारा अपलोड की गई प्रत्येक फ़ाइल पर समान संपादन कॉपी करने के लिए "सभी छवियों पर लागू करें" का उपयोग करें।</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        किसी खाते की आवश्यकता नहीं है। आपकी फ़ाइलें हमारे सर्वर पर कभी संग्रहीत नहीं होती हैं।
      </p>
    </div>

    <%# ── Editable fields table ──────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">संदर्भ</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">संपादन योग्य EXIF फ़ील्ड</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        नीचे सूचीबद्ध प्रत्येक फ़ील्ड को सीधे एडिटर में पढ़ा, संपादित किया या साफ़ किया जा सकता है। डाउनलोड करने पर परिवर्तन इमेज फ़ाइल में वापस लिख दिए जाते हैं — आपकी फ़ोटो की दृश्य सामग्री को कभी नहीं छुआ जाता है।
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">EXIF फ़ील्ड</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">आप क्या सेट कर सकते हैं</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["GPS अक्षांश / देशांतर", "उस स्थान को जोड़ें, बदलें या हटाएँ जहाँ फ़ोटो ली गई थी"],
              ["DateTimeOriginal",         "गलत शूटिंग दिनांक को ठीक करें या गलत समय क्षेत्र को सही करें"],
              ["कलाकार / निर्माता",         "अपना नाम जोड़ें ताकि आपकी लेखकता फ़ाइल के साथ रहे"],
              ["कॉपीराइट",               "एक कॉपीराइट स्टेटमेंट एम्बेड करें (उदाहरण के लिए © 2026 जेन स्मिथ)"],
              ["कीवर्ड",                "स्टॉक लाइब्रेरी या एसेट प्रबंधन के लिए खोज योग्य टैग जोड़ें"],
              ["ImageDescription",        "इमेज के लिए कैप्शन या alt-text विवरण लिखें"],
              ["मेक / मॉडल",            "कैमरा ब्रांड और मॉडल फ़ील्ड को अपडेट या साफ़ करें"],
            ].each do |field, purpose| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= field %></td>
                <td class="text-sm text-base-content/60"><%= purpose %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">फ़ाइल के एम्बेडेड डेटा के आधार पर अतिरिक्त फ़ील्ड केवल-पढ़ने वाले मोड में दिखाई दे सकते हैं।</p>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">उपयोग के मामले</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">EXIF मेटाडेटा क्यों संपादित करें?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["कॉपीराइट और क्रेडिट जोड़ें",     "अपना नाम, कॉपीराइट स्टेटमेंट और संपर्क विवरण सीधे फ़ाइल में एम्बेड करें ताकि स्वामित्व जानकारी इमेज के साथ रहे, चाहे वह कहीं भी जाए।"],
          ["गलत दिनांक या समय ठीक करें",      "कैमरा घड़ियाँ भटक जाती हैं, समय क्षेत्रों में यात्रा करती हैं, या बैटरी बदलने के बाद रीसेट हो जाती हैं। शूटिंग की तारीख को सही करें ताकि आपकी फोटो लाइब्रेरी सटीक रूप से व्यवस्थित रहे।"],
          ["अनटैग की गई फ़ोटो में GPS जोड़ें",  "बिना GPS वाले कैमरे से ली गई फ़ोटो? स्थान निर्देशांक मैन्युअल रूप से जोड़ें ताकि फ़ोटो मानचित्रों पर और स्थान-आधारित खोजों में सही ढंग से दिखाई दे।"],
          ["स्टॉक फ़ोटो की तैयारी",     "स्टॉक लाइब्रेरी को फ़ाइल में सटीक कॉपीराइट, कीवर्ड और विवरण एम्बेड करने की आवश्यकता होती है। समीक्षा प्रक्रिया को तेज़ करने के लिए सबमिशन से पहले सभी आवश्यक फ़ील्ड संपादित करें।"],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Apply to all feature ───────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">थोक संपादन</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">कई छवियों पर संपादन लागू करें</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        एडिटर एक समय में एक इमेज पर काम करता है, लेकिन आप एक ही सत्र में कई फ़ाइलें अपलोड कर सकते हैं। पहली इमेज को संपादित करने के बाद, <strong class="text-base-content font-semibold">"सभी छवियों पर लागू करें"</strong> बटन का उपयोग करके अपने वर्तमान मेटाडेटा परिवर्तनों को हर दूसरी अपलोड की गई फ़ाइल में कॉपी करें — जिससे आपको एक-एक करके वही संपादन दोहराने से बचाया जा सके।
      </p>
      <ul class="space-y-4">
        <% [
          ["एक शूट में सुसंगत कॉपीराइट",  "एक क्लिक में एक सत्र से प्रत्येक इमेज पर अपना कॉपीराइट स्टेटमेंट और कलाकार का नाम लागू करें।"],
          ["एक फोटो सेट के लिए साझा कीवर्ड",       "स्टॉक लाइब्रेरी या क्लाइंट फ़ोल्डर के लिए निर्धारित सभी छवियों पर समान वर्णनात्मक कीवर्ड सेट करें।"],
          ["समान GPS टैगिंग",                   "एक ही स्थान या कार्यक्रम में ली गई सभी तस्वीरों को एक ही स्थान असाइन करें।"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">अक्सर पूछे जाने वाले प्रश्न</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">अक्सर पूछे जाने वाले प्रश्न</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["कौन सा EXIF डेटा संपादित किया जा सकता है?",
           "आप GPS निर्देशांक, दिनांक और समय (DateTimeOriginal), कलाकार/निर्माता का नाम, कॉपीराइट स्टेटमेंट, कीवर्ड, इमेज विवरण/कैप्शन और कैमरा मेक/मॉडल संपादित कर सकते हैं। जिन फ़ील्ड को आप खाली छोड़ते हैं, वे फ़ाइल से हटा दिए जाते हैं। मूल फ़ाइल में क्या है, इसके आधार पर अतिरिक्त केवल-पढ़ने वाले फ़ील्ड प्रदर्शित हो सकते हैं।"],
          ["क्या EXIF डेटा संपादित करने से इमेज की गुणवत्ता बदल जाती है?",
           "नहीं। EXIF संपादन केवल मेटाडेटा परत को संशोधित करता है — आपकी फ़ोटो बनाने वाले पिक्सेल डेटा को कभी नहीं छुआ जाता है। आपकी इमेज संपादन से पहले और बाद में समान दिखेगी, और फ़ाइल प्रारूप वही रहेगा।"],
          ["कौन से फ़ाइल प्रारूप समर्थित हैं?",
           "JPEG और PNG EXIF मेटाडेटा को पढ़ने और लिखने के लिए पूरी तरह से समर्थित हैं। JPEG EXIF डेटा के लिए सबसे सामान्य प्रारूप है और फ़ील्ड की सबसे विस्तृत श्रृंखला का समर्थन करता है। PNG मेटाडेटा फ़ील्ड के एक उपसमूह का समर्थन करता है। WebP और GIF में सीमित या कोई EXIF समर्थन नहीं है, यह इस बात पर निर्भर करता है कि उन्हें कैसे बनाया गया था।"],
          ["मैं एक फ़ोटो में GPS निर्देशांक कैसे जोड़ूँ?",
           "एडिटर में इमेज खोलें, GPS अक्षांश और देशांतर फ़ील्ड ढूंढें, और स्थान के लिए दशमलव निर्देशांक दर्ज करें (उदाहरण के लिए एफिल टॉवर के लिए 48.8584, 2.2945)। आप Google Maps का उपयोग करके किसी भी स्थान के लिए निर्देशांक ढूंढ सकते हैं — एक स्थान पर राइट-क्लिक करें और दिखाए गए निर्देशांक कॉपी करें।"],
          ["मैं अपनी फ़ोटो में कॉपीराइट स्टेटमेंट कैसे जोड़ूँ?",
           "अपनी इमेज अपलोड करें, कॉपीराइट फ़ील्ड में अपना कॉपीराइट टेक्स्ट दर्ज करें (उदाहरण के लिए: © 2026 आपका नाम। सभी अधिकार सुरक्षित।), और सहेजें। कई अपलोड की गई छवियों पर समान कॉपीराइट लागू करने के लिए, पहली इमेज को संपादित करने के बाद \"सभी छवियों पर लागू करें\" पर क्लिक करें।"],
          ["\"सभी छवियों पर लागू करें\" क्या करता है?",
           "जब आपके पास एक ही सत्र में कई छवियां अपलोड होती हैं, तो \"सभी छवियों पर लागू करें\" आपके द्वारा वर्तमान इमेज पर संपादित किए गए मेटाडेटा फ़ील्ड को आपकी अपलोड कतार में हर दूसरी फ़ाइल में कॉपी करता है। यह प्रत्येक फ़ाइल के लिए मैन्युअल रूप से संपादन दोहराए बिना एक पूरे फोटो सेट में सुसंगत कॉपीराइट, कीवर्ड या स्थान डेटा लागू करने का एक शॉर्टकट है।"],
        ].each do |question, answer| %>
          <div class="collapse collapse-plus rounded-xl border border-base-200 bg-base-100 hover:border-primary/20 transition-colors">
            <input type="checkbox">
            <div class="collapse-title font-semibold text-base-content text-sm"><%= question %></div>
            <div class="collapse-content">
              <p class="text-sm text-base-content/60 leading-relaxed"><%= answer %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Footer note ─────────────────────────────────────────────────── %>
    <p class="text-xs text-base-content/25 text-right">अंतिम अपडेट: मई 2026</p>

  </div>
</section>
