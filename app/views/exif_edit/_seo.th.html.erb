<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        แก้ไขข้อมูลเมตา EXIF ออนไลน์ —<br class="hidden sm:block"> โปรแกรมแก้ไขข้อมูลรูปภาพฟรี
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        ดูและแก้ไขข้อมูลเมตาที่ซ่อนอยู่ในรูปภาพของคุณ — ไม่ต้องใช้ซอฟต์แวร์ ไม่ต้องลงทะเบียน โปรแกรมแก้ไข EXIF ออนไลน์ฟรีของเราช่วยให้คุณสามารถเปลี่ยนพิกัด GPS, แก้ไขวันที่และเวลา, เพิ่มข้อมูลลิขสิทธิ์และผู้เขียน, อัปเดตคีย์เวิร์ด และอื่นๆ อีกมากมาย ใช้งานได้กับไฟล์ JPEG และ PNG เหมาะสำหรับช่างภาพ, ผู้ร่วมให้ข้อมูลสต็อก และทุกคนที่ต้องการควบคุมข้อมูลรูปภาพได้อย่างแม่นยำ
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/exif_edit_hero.png", alt: "โปรแกรมแก้ไข EXIF ออนไลน์ — แก้ไข GPS, วันที่, ลิขสิทธิ์ และฟิลด์ข้อมูลเมตาในไฟล์ JPEG และ PNG", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ทีละขั้นตอน</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">วิธีแก้ไขข้อมูลเมตา EXIF ออนไลน์</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">อัปโหลดรูปภาพของคุณ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">ลากและวาง หรือคลิกเพื่อเลือกไฟล์ JPEG หรือ PNG คุณสามารถอัปโหลดรูปภาพหลายไฟล์และแก้ไขทีละไฟล์ได้</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">แก้ไขฟิลด์ข้อมูลเมตา</p>
            <p class="text-sm text-base-content/55 leading-relaxed">อัปเดตฟิลด์ EXIF ใดๆ — พิกัด GPS, วันที่ถ่าย, ข้อมูลกล้อง, ลิขสิทธิ์, ชื่อศิลปิน, คีย์เวิร์ด หรือคำอธิบาย เว้นฟิลด์ว่างไว้เพื่อลบออก</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">ใช้และดาวน์โหลด</p>
            <p class="text-sm text-base-content/55 leading-relaxed">คลิกบันทึกเพื่อเขียนการเปลี่ยนแปลงของคุณ จากนั้นดาวน์โหลดรูปภาพที่อัปเดต ใช้ "ใช้กับรูปภาพทั้งหมด" เพื่อคัดลอกการแก้ไขเดียวกันไปยังทุกไฟล์ที่คุณอัปโหลด</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        ไม่ต้องมีบัญชี ไฟล์ของคุณจะไม่ถูกเก็บไว้บนเซิร์ฟเวอร์ของเรา
      </p>
    </div>

    <%# ── Editable fields table ──────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">อ้างอิง</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ฟิลด์ EXIF ที่แก้ไขได้</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        ทุกฟิลด์ที่ระบุไว้ด้านล่างสามารถอ่าน แก้ไข หรือล้างได้โดยตรงในโปรแกรมแก้ไข การเปลี่ยนแปลงจะถูกเขียนกลับลงในไฟล์รูปภาพเมื่อดาวน์โหลด — เนื้อหาภาพถ่ายของคุณจะไม่ถูกแตะต้อง
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">ฟิลด์ EXIF</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">สิ่งที่คุณสามารถตั้งค่าได้</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["ละติจูด / ลองจิจูด GPS", "เพิ่ม เปลี่ยน หรือลบตำแหน่งที่ถ่ายภาพ"],
              ["DateTimeOriginal",         "แก้ไขวันที่ถ่ายที่ไม่ถูกต้อง หรือแก้ไขเขตเวลาที่ผิด"],
              ["ศิลปิน / ผู้สร้าง",         "เพิ่มชื่อของคุณเพื่อให้ความเป็นเจ้าของผลงานอยู่กับไฟล์"],
              ["ลิขสิทธิ์",               "ฝังข้อความลิขสิทธิ์ (เช่น © 2026 Jane Smith)"],
              ["คีย์เวิร์ด",                "เพิ่มแท็กที่ค้นหาได้สำหรับคลังภาพสต็อก หรือการจัดการสินทรัพย์"],
              ["ImageDescription",        "เขียนคำบรรยายภาพ หรือคำอธิบาย alt-text สำหรับรูปภาพ"],
              ["ยี่ห้อ / รุ่น",            "อัปเดต หรือล้างฟิลด์ยี่ห้อและรุ่นกล้อง"],
            ].each do |field, purpose| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= field %></td>
                <td class="text-sm text-base-content/60"><%= purpose %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">ฟิลด์เพิ่มเติมอาจปรากฏในโหมดอ่านอย่างเดียว ขึ้นอยู่กับข้อมูลที่ฝังอยู่ในไฟล์</p>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">กรณีการใช้งาน</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ทำไมต้องแก้ไขข้อมูลเมตา EXIF?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["เพิ่มลิขสิทธิ์และเครดิต",     "ฝังชื่อของคุณ, ข้อความลิขสิทธิ์ และรายละเอียดการติดต่อลงในไฟล์โดยตรง เพื่อให้ข้อมูลความเป็นเจ้าของอยู่กับรูปภาพไม่ว่าจะถูกส่งไปที่ใด"],
          ["แก้ไขวันที่หรือเวลาที่ผิด",      "นาฬิกากล้องอาจคลาดเคลื่อน, เดินทางข้ามเขตเวลา หรือถูกรีเซ็ตหลังจากการเปลี่ยนแบตเตอรี่ แก้ไขวันที่ถ่ายเพื่อให้คลังภาพของคุณจัดเรียงได้อย่างถูกต้อง"],
          ["เพิ่ม GPS ให้กับรูปภาพที่ไม่มีแท็ก",  "ถ่ายด้วยกล้องที่ไม่มี GPS ใช่หรือไม่? เพิ่มพิกัดตำแหน่งด้วยตนเองเพื่อให้รูปภาพปรากฏอย่างถูกต้องบนแผนที่และในการค้นหาตามตำแหน่ง"],
          ["การเตรียมภาพสต็อก",     "คลังภาพสต็อกต้องการลิขสิทธิ์, คีย์เวิร์ด และคำอธิบายที่ถูกต้องฝังอยู่ในไฟล์ แก้ไขฟิลด์ที่จำเป็นทั้งหมดก่อนส่งเพื่อเร่งกระบวนการตรวจสอบ"],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Apply to all feature ───────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">การแก้ไขจำนวนมาก</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ใช้การแก้ไขกับรูปภาพหลายไฟล์</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        โปรแกรมแก้ไขทำงานกับรูปภาพทีละไฟล์ แต่คุณสามารถอัปโหลดหลายไฟล์ได้ในการทำงานครั้งเดียว หลังจากแก้ไขรูปภาพแรกแล้ว ให้ใช้ปุ่ม <strong class="text-base-content font-semibold">"ใช้กับรูปภาพทั้งหมด"</strong> เพื่อคัดลอกการเปลี่ยนแปลงข้อมูลเมตาปัจจุบันของคุณไปยังไฟล์ที่อัปโหลดอื่นๆ ทั้งหมด — ช่วยให้คุณไม่ต้องทำซ้ำการแก้ไขเดียวกันทีละไฟล์
      </p>
      <ul class="space-y-4">
        <% [
          ["ลิขสิทธิ์ที่สอดคล้องกันตลอดการถ่ายภาพ",  "ใช้ข้อความลิขสิทธิ์และชื่อศิลปินของคุณกับทุกรูปภาพจากการถ่ายภาพในคลิกเดียว"],
          ["คีย์เวิร์ดที่ใช้ร่วมกันสำหรับชุดภาพถ่าย",       "ตั้งค่าคีย์เวิร์ดอธิบายเดียวกันสำหรับรูปภาพทั้งหมดที่มุ่งหมายสำหรับคลังภาพสต็อกหรือโฟลเดอร์ลูกค้า"],
          ["การแท็ก GPS ที่สม่ำเสมอ",                   "กำหนดตำแหน่งเดียวกันให้กับรูปภาพทั้งหมดที่ถ่ายในสถานที่หรือเหตุการณ์เดียวกัน"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">คำถามที่พบบ่อย</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">คำถามที่พบบ่อย</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["ข้อมูล EXIF ใดบ้างที่สามารถแก้ไขได้?",
           "คุณสามารถแก้ไขพิกัด GPS, วันที่และเวลา (DateTimeOriginal), ชื่อศิลปิน/ผู้สร้าง, ข้อความลิขสิทธิ์, คีย์เวิร์ด, คำอธิบายภาพ/คำบรรยาย และยี่ห้อ/รุ่นกล้อง ฟิลด์ที่คุณเว้นว่างไว้จะถูกล้างออกจากไฟล์ ฟิลด์อ่านอย่างเดียวเพิ่มเติมอาจแสดงขึ้นอยู่กับสิ่งที่ไฟล์ต้นฉบับมีอยู่"],
          ["การแก้ไขข้อมูล EXIF เปลี่ยนคุณภาพของภาพหรือไม่?",
           "ไม่ การแก้ไข EXIF จะปรับเปลี่ยนเฉพาะชั้นข้อมูลเมตาเท่านั้น — ข้อมูลพิกเซลที่ประกอบเป็นภาพถ่ายของคุณจะไม่ถูกแตะต้อง ภาพของคุณจะดูเหมือนเดิมทั้งก่อนและหลังการแก้ไข และรูปแบบไฟล์ยังคงเดิม"],
          ["รองรับรูปแบบไฟล์ใดบ้าง?",
           "JPEG และ PNG รองรับการอ่านและเขียนข้อมูลเมตา EXIF อย่างเต็มที่ JPEG เป็นรูปแบบที่พบบ่อยที่สุดสำหรับข้อมูล EXIF และรองรับฟิลด์ที่หลากหลายที่สุด PNG รองรับชุดย่อยของฟิลด์ข้อมูลเมตา WebP และ GIF มีการรองรับ EXIF ที่จำกัดหรือไม่รองรับเลย ขึ้นอยู่กับวิธีการสร้าง"],
          ["ฉันจะเพิ่มพิกัด GPS ให้กับรูปภาพได้อย่างไร?",
           "เปิดรูปภาพในโปรแกรมแก้ไข ค้นหาฟิลด์ละติจูดและลองจิจูด GPS และป้อนพิกัดทศนิยมสำหรับตำแหน่ง (เช่น 48.8584, 2.2945 สำหรับหอไอเฟล) คุณสามารถค้นหาพิกัดสำหรับตำแหน่งใดก็ได้โดยใช้ Google Maps — คลิกขวาที่จุดแล้วคัดลอกพิกัดที่แสดง"],
          ["ฉันจะเพิ่มข้อความลิขสิทธิ์ให้กับรูปภาพของฉันได้อย่างไร?",
           "อัปโหลดรูปภาพของคุณ ป้อนข้อความลิขสิทธิ์ของคุณในฟิลด์ลิขสิทธิ์ (ตัวอย่าง: © 2026 ชื่อของคุณ สงวนลิขสิทธิ์) และบันทึก หากต้องการใช้ลิขสิทธิ์เดียวกันกับรูปภาพที่อัปโหลดหลายไฟล์ ให้คลิก \"ใช้กับรูปภาพทั้งหมด\" หลังจากแก้ไขรูปภาพแรก"],
          ["\"ใช้กับรูปภาพทั้งหมด\" ทำอะไร?",
           "เมื่อคุณอัปโหลดรูปภาพหลายไฟล์ในการทำงานครั้งเดียวกัน \"ใช้กับรูปภาพทั้งหมด\" จะคัดลอกฟิลด์ข้อมูลเมตาที่คุณแก้ไขในรูปภาพปัจจุบันไปยังไฟล์อื่นๆ ทั้งหมดในคิวการอัปโหลดของคุณ เป็นทางลัดสำหรับการใช้ลิขสิทธิ์, คีย์เวิร์ด หรือข้อมูลตำแหน่งที่สอดคล้องกันกับชุดภาพถ่ายทั้งหมด โดยไม่ต้องทำซ้ำการแก้ไขด้วยตนเองสำหรับแต่ละไฟล์"],
        ].each do |question, answer| %>
          <div class="collapse collapse-plus rounded-xl border border-base-200 bg-base-100 hover:border-primary/20 transition-colors">
            <input type="checkbox">
            <div class="collapse-title font-semibold text-base-content text-sm"><%= question %></div>
            <div class="collapse-content">
              <p class="text-sm text-base-content/60 leading-relaxed"><%= answer %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Footer note ─────────────────────────────────────────────────── %>
    <p class="text-xs text-base-content/25 text-right">อัปเดตล่าสุด: พฤษภาคม 2026</p>

  </div>
</section>
