<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        在线编辑 EXIF 元数据 —<br class="hidden sm:block"> 免费图像数据编辑器
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        查看并编辑图像中隐藏的元数据 — 无需软件，无需注册。我们的免费在线 EXIF 编辑器可让您更改 GPS 坐标、修正日期和时间戳、添加版权和作者信息、更新关键词等。支持 JPEG 和 PNG 文件。非常适合摄影师、图库贡献者以及任何需要精确控制图像数据的人。
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/exif_edit_hero.png", alt: "在线 EXIF 编辑器 — 编辑 JPEG 和 PNG 文件中的 GPS、日期、版权和元数据字段", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">分步指南</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">如何在线编辑 EXIF 元数据</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">上传您的图片</p>
            <p class="text-sm text-base-content/55 leading-relaxed">拖放或点击选择 JPEG 或 PNG 文件。您可以上传多张图片并逐一编辑。</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">编辑元数据字段</p>
            <p class="text-sm text-base-content/55 leading-relaxed">更新任何 EXIF 字段 — GPS 坐标、拍摄日期、相机信息、版权、艺术家姓名、关键词或描述。留空字段以将其删除。</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">应用并下载</p>
            <p class="text-sm text-base-content/55 leading-relaxed">点击“保存”以写入您的更改，然后下载更新后的图片。使用“应用到所有图片”将相同的编辑复制到您上传的每个文件。</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        无需账户。您的文件绝不会存储在我们的服务器上。
      </p>
    </div>

    <%# ── Editable fields table ──────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">参考</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">可编辑的 EXIF 字段</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        下面列出的每个字段都可以在编辑器中直接读取、编辑或清除。更改将在下载时写回图像文件 — 您的照片的视觉内容绝不会被触及。
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">EXIF 字段</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">您可以设置的内容</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["GPS 纬度 / 经度", "添加、更改或删除照片的拍摄地点"],
              ["DateTimeOriginal",         "修正不正确的拍摄日期或纠正错误的时区"],
              ["艺术家 / 创作者",         "添加您的姓名，以便您的著作权随文件传播"],
              ["版权",               "嵌入版权声明（例如 © 2026 Jane Smith）"],
              ["关键词",                "为图库或资产管理添加可搜索的标签"],
              ["ImageDescription",        "为图片撰写说明或 alt 文本描述"],
              ["品牌 / 型号",            "更新或清除相机品牌和型号字段"],
            ].each do |field, purpose| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= field %></td>
                <td class="text-sm text-base-content/60"><%= purpose %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">根据文件嵌入的数据，可能还会显示其他只读字段。</p>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">使用场景</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">为什么要编辑 EXIF 元数据？</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["添加版权和署名",     "将您的姓名、版权声明和联系方式直接嵌入文件中，以便所有权信息无论文件传播到何处都随之保留。"],
          ["修正错误的日期或时间",      "相机时钟会漂移、跨越时区，或在更换电池后重置。修正拍摄日期，使您的照片库保持准确排序。"],
          ["为未标记的照片添加 GPS",  "相机没有 GPS 功能？手动添加位置坐标，以便照片在地图和基于位置的搜索中正确显示。"],
          ["图库照片准备",     "图库要求文件中嵌入准确的版权、关键词和描述。在提交前编辑所有必填字段，以加快审核过程。"],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Apply to all feature ───────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">批量编辑</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">将编辑应用到多张图片</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        编辑器一次处理一张图片，但您可以在一个会话中上传多个文件。编辑第一张图片后，使用 <strong class="text-base-content font-semibold">“应用到所有图片”</strong> 按钮将您当前的元数据更改复制到所有其他已上传的文件 — 从而避免逐一重复相同的编辑。
      </p>
      <ul class="space-y-4">
        <% [
          ["拍摄作品的版权一致性",  "一键将您的版权声明和艺术家姓名应用到会话中的每张图片。"],
          ["照片集的共享关键词",       "为所有用于图库或客户文件夹的图片设置相同的描述性关键词。"],
          ["统一的 GPS 标记",                   "将相同的地点分配给在同一场地或活动中拍摄的所有照片。"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <%
