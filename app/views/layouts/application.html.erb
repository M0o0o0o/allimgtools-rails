<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-theme="light">

<head>
    <title><%= content_for(:title) || t("home.meta_title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || t("home.meta_description") %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Allimgtools">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Canonical URL — always points to English (default) version %>
    <% canonical_path = request.path.sub(%r{\A/(#{PUBLIC_LOCALE_PATTERN})(/|\z)}, '/') %>
    <link rel="canonical" href="https://allimgtools.com<%= canonical_path == '/' ? '' : canonical_path %>">

    <%# hreflang tags for SEO %>
    <%# Blog is English-only — only declare en + x-default to avoid duplicate content signals %>
    <% if controller_name == "posts" %>
      <link rel="alternate" hreflang="en" href="https://allimgtools.com<%= canonical_path == "/" ? "" : canonical_path %>">
      <link rel="alternate" hreflang="x-default" href="https://allimgtools.com<%= canonical_path == "/" ? "" : canonical_path %>">
    <% else %>
      <% SUPPORTED_LOCALES.each_key do |locale| %>
        <link rel="alternate" hreflang="<%= locale %>"
              href="https://allimgtools.com<%= url_for(locale: locale == I18n.default_locale ? nil : locale, only_path: true) %>">
      <% end %>
      <link rel="alternate" hreflang="x-default"
            href="https://allimgtools.com<%= url_for(locale: nil, only_path: true) %>">
    <% end %>

    <%# Open Graph %>
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Allimgtools">
    <meta property="og:title" content="<%= content_for(:title) || t("home.meta_title") %>">
    <meta property="og:description" content="<%= content_for(:description) || t("home.meta_description") %>">
    <meta property="og:url" content="https://allimgtools.com<%= canonical_path == '/' ? '' : canonical_path %>">
    <meta property="og:locale" content="<%= controller_name == "posts" ? "en" : I18n.locale.to_s.gsub('-', '_') %>">
    <% unless controller_name == "posts" %>
      <% (SUPPORTED_LOCALES.keys.map(&:to_s) - [ I18n.locale.to_s ]).each do |loc| %>
    <meta property="og:locale:alternate" content="<%= loc.gsub('-', '_') %>">
      <% end %>
    <% end %>

    <%# Twitter Card %>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= content_for(:title) || t("home.meta_title") %>">
    <meta name="twitter:description" content="<%= content_for(:description) || t("home.meta_description") %>">

    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" sizes="48x48">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-96x96.png" type="image/png" sizes="96x96">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0Y6WGXCBC1"></script>
    <script>
        window.dataLayer = window.dataLayer || [];

        function gtag() {
            dataLayer.push(arguments);
        }
        gtag('js', new Date());

        gtag('config', 'G-0Y6WGXCBC1');
    </script>
</head>

<body class="bg-base-200 min-h-screen">
    <div class="drawer">
        <input id="nav-drawer" type="checkbox" class="drawer-toggle" />

        <div class="drawer-content flex flex-col min-h-screen">
            <%= render "shared/header" %>

            <main class="<%= content_for?(:main_class) ? yield(:main_class) : 'container mx-auto px-4 py-8 max-w-4xl flex-1' %>">
                <%= yield %>
            </main>

            <% unless controller_name.in?(%w[compress resize convert exif rotate crop downloads]) %>
            <footer class="bg-base-100 border-t border-base-200 mt-auto">
                <div class="container mx-auto px-4 pt-10 pb-8 max-w-5xl">
                    <%# Top row: brand + links %>
                    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 mb-8">
                        <%# Brand %>
                        <div class="flex flex-col gap-1.5">
                            <%= link_to root_path, class: "flex items-center gap-2" do %>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                <span class="font-bold text-base-content">allimgtools</span>
                            <% end %>
                            <p class="text-xs text-base-content/40 pl-7">Free online image tools. No signup required.</p>
                        </div>

                        <%# Links %>
                        <nav class="flex items-center gap-6 text-sm">
                            <%= link_to t("nav.blog"), posts_path, class: "text-base-content/50 hover:text-primary transition-colors font-medium #{controller_name == 'posts' ? 'text-primary' : ''}" %>
                            <%= link_to "Pricing", pricing_path, class: "text-base-content/50 hover:text-primary transition-colors font-medium #{controller_name == 'pages' && action_name == 'pricing' ? 'text-primary' : ''}" %>
                            <%= link_to "Terms", terms_path, class: "text-base-content/50 hover:text-primary transition-colors font-medium #{controller_name == 'pages' && action_name == 'terms' ? 'text-primary' : ''}" %>
                            <%= link_to "Privacy", privacy_path, class: "text-base-content/50 hover:text-primary transition-colors font-medium #{controller_name == 'pages' && action_name == 'privacy' ? 'text-primary' : ''}" %>
                        </nav>
                    </div>

                    <%# Divider %>
                    <div class="border-t border-base-200"></div>

                    <%# Bottom row: copyright %>
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-2 mt-5 text-xs text-base-content/35">
                        <span>&copy; <%= Date.today.year %> allimgtools. All rights reserved.</span>
                        <span>Free to use &middot; No data stored &middot; Files deleted after 3 hours</span>
                    </div>
                </div>
            </footer>
            <% end %>
        </div>

        <%# Mobile slide menu %>
        <div class="drawer-side z-[100]">
            <label for="nav-drawer" aria-label="<%= t("common.close") %>" class="drawer-overlay"></label>
            <nav class="bg-base-100 min-h-full w-64 shadow-xl flex flex-col">
                <div class="p-4 border-b border-base-200">
                    <%= link_to root_path, class: "flex items-center gap-2 font-bold text-lg" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    allimgtools
                    <% end %>
                </div>
                <nav class="p-3 flex-1 flex flex-col gap-0.5">
                    <% [
                        { path: new_compress_path, active: controller_name == 'compress', label: t("nav.compress"),
                          icon: "M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" },
                        { path: new_resize_path,   active: controller_name == 'resize',   label: t("nav.resize"),
                          icon: "M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" },
                        { path: new_rotate_path,   active: controller_name == 'rotate',   label: t("nav.rotate"),
                          icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" },
                        { path: new_crop_path,     active: controller_name == 'crop',     label: t("nav.crop"),
                          icon: "M3 10h4V3m14 14h-4v7M3 10l18 11M3 10L21 3" },
                        { path: new_exif_path,     active: controller_name == 'exif',     label: t("nav.exif"),
                          icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
                    ].each do |item| %>
                        <%= link_to item[:path],
                              class: "flex items-center gap-3 px-3 py-3 rounded-xl text-base font-medium transition-colors #{item[:active] ? 'bg-primary/10 text-primary' : 'text-base-content/90 hover:bg-base-200 hover:text-base-content'}" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item[:icon] %>"/>
                            </svg>
                            <%= item[:label] %>
                        <% end %>
                    <% end %>

                    <%# Convert submenu %>
                    <details <%= controller_name == 'convert' ? 'open' : '' %> class="group">
                        <summary class="flex items-center gap-3 px-3 py-3 rounded-xl text-base font-medium transition-colors cursor-pointer list-none <%= controller_name == 'convert' ? 'bg-primary/10 text-primary' : 'text-base-content/90 hover:bg-base-200 hover:text-base-content' %>">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                            </svg>
                            <span class="flex-1"><%= t("nav.convert") %></span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </summary>
                        <div class="mt-0.5 ml-4 pl-4 border-l border-base-200 flex flex-col gap-0.5">
                            <%= link_to t("nav.image_converter"), new_convert_path, class: "px-3 py-2.5 rounded-lg text-sm font-medium text-base-content/80 hover:bg-base-200 hover:text-base-content transition-colors" %>
                            <%= link_to "JPG → PNG",  jpg_to_png_path,  class: "px-3 py-2.5 rounded-lg text-sm font-medium text-base-content/80 hover:bg-base-200 hover:text-base-content transition-colors" %>
                            <%= link_to "JPG → WebP", jpg_to_webp_path, class: "px-3 py-2.5 rounded-lg text-sm font-medium text-base-content/80 hover:bg-base-200 hover:text-base-content transition-colors" %>
                            <%= link_to "PNG → JPG",  png_to_jpg_path,  class: "px-3 py-2.5 rounded-lg text-sm font-medium text-base-content/80 hover:bg-base-200 hover:text-base-content transition-colors" %>
                            <%= link_to "PNG → WebP", png_to_webp_path, class: "px-3 py-2.5 rounded-lg text-sm font-medium text-base-content/80 hover:bg-base-200 hover:text-base-content transition-colors" %>
                            <%= link_to "WebP → JPG", webp_to_jpg_path, class: "px-3 py-2.5 rounded-lg text-sm font-medium text-base-content/80 hover:bg-base-200 hover:text-base-content transition-colors" %>
                            <%= link_to "WebP → PNG", webp_to_png_path, class: "px-3 py-2.5 rounded-lg text-sm font-medium text-base-content/80 hover:bg-base-200 hover:text-base-content transition-colors" %>
                        </div>
                    </details>
                </nav>

                <%# Language switcher in mobile drawer %>
                <div class="p-3 border-t border-base-200">
                    <details class="group">
                        <summary class="flex items-center gap-3 px-3 py-3 rounded-xl text-base font-medium text-base-content/90 hover:bg-base-200 hover:text-base-content transition-colors cursor-pointer list-none">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                            </svg>
                            <span class="flex-1"><%= t("nav.language") %></span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </summary>
                        <div class="mt-0.5 ml-4 pl-4 border-l border-base-200 flex flex-col gap-0.5">
                            <% SUPPORTED_LOCALES.each do |locale, info| %>
                                <%= link_to url_for(locale: locale.to_s == I18n.default_locale.to_s ? nil : locale),
                                      class: "flex items-center justify-between px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{I18n.locale.to_s == locale.to_s ? 'text-primary font-semibold' : 'text-base-content/80 hover:bg-base-200 hover:text-base-content'}" do %>
                                    <%= info[:native] %>
                                    <% if I18n.locale.to_s == locale.to_s %>
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                                        </svg>
                                    <% end %>
                                <% end %>
                            <% end %>
                        </div>
                    </details>
                </div>
            </nav>
        </div>
    </div>
</body>

</html>
