<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <title><%= content_for(:title) || "Allimgtools — Free Online Image Tools" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || "Free online image tools. Compress and resize JPEG, PNG, WebP, GIF, and AVIF images instantly. No signup required. Files deleted after 3 hours." %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Allimgtools">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Canonical URL %>
    <link rel="canonical" href="https://allimgtools.com<%= request.path == '/' ? '' : request.path %>">

    <%# Open Graph %>
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Allimgtools">
    <meta property="og:title" content="<%= content_for(:title) || "Allimgtools — Free Online Image Tools" %>">
    <meta property="og:description" content="<%= content_for(:description) || "Free online image tools. Compress and resize JPEG, PNG, WebP, GIF, and AVIF images instantly. No signup required." %>">
    <meta property="og:url" content="https://allimgtools.com<%= request.path == '/' ? '' : request.path %>">

    <%# Twitter Card %>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= content_for(:title) || "Allimgtools — Free Online Image Tools" %>">
    <meta name="twitter:description" content="<%= content_for(:description) || "Free online image tools. Compress and resize JPEG, PNG, WebP, GIF, and AVIF images instantly. No signup required." %>">

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0Y6WGXCBC1"></script>
    <script>
        window.dataLayer = window.dataLayer || [];

        function gtag() {
            dataLayer.push(arguments);
        }
        gtag('js', new Date());

        gtag('config', 'G-0Y6WGXCBC1');
    </script>
</head>

<body class="bg-base-200 min-h-screen">
    <div class="drawer">
        <input id="nav-drawer" type="checkbox" class="drawer-toggle" />

        <div class="drawer-content flex flex-col min-h-screen">
            <%= render "shared/header" %>

            <main class="<%= content_for?(:main_class) ? yield(:main_class) : 'container mx-auto px-4 py-8 max-w-4xl flex-1' %>">
                <%= yield %>
            </main>
        </div>

        <%# Mobile slide menu %>
        <div class="drawer-side z-[100]">
            <label for="nav-drawer" aria-label="Close menu" class="drawer-overlay"></label>
            <nav class="bg-base-100 min-h-full w-64 shadow-xl flex flex-col">
                <div class="p-4 border-b border-base-200">
                    <%= link_to root_path, class: "flex items-center gap-2 font-bold text-lg" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    allimgtools
                    <% end %>
                </div>
                <ul class="menu p-4 gap-1 flex-1">
                    <li>
                        <%= link_to new_compress_path, class: "#{controller_name == 'compress' ? 'active' : ''}" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                        </svg>
                        Image Compress
                        <% end %>
                    </li>
                    <li>
                        <%= link_to new_resize_path, class: "#{controller_name == 'resize' ? 'active' : ''}" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                        </svg>
                        Image Resize
                        <% end %>
                    </li>
                    <li>
                        <details <%= controller_name == 'convert' ? 'open' : '' %>>
                            <summary class="<%= controller_name == 'convert' ? 'active' : '' %>">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                                </svg>
                                Image Convert
                            </summary>
                            <ul>
                                <li><%= link_to "Image Converter", new_convert_path %></li>
                                <li><%= link_to "JPG → PNG",  jpg_to_png_path %></li>
                                <li><%= link_to "JPG → WebP", jpg_to_webp_path %></li>
                                <li><%= link_to "PNG → JPG",  png_to_jpg_path %></li>
                                <li><%= link_to "PNG → WebP", png_to_webp_path %></li>
                                <li><%= link_to "WebP → JPG", webp_to_jpg_path %></li>
                                <li><%= link_to "WebP → PNG", webp_to_png_path %></li>
                            </ul>
                        </details>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</body>

</html>