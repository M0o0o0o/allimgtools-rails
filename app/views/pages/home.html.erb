<% content_for :title, t("home.meta_title") %>
<% content_for :description, t("home.meta_description") %>
<% content_for :head do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Allimgtools",
    "url": "https://allimgtools.com",
    "description": "Free online image tools. Compress, resize, and convert images instantly.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://allimgtools.com"
    }
  }
  </script>
<% end %>

<div class="max-w-2xl mx-auto">
    <div class="text-center mb-12">
        <h1 class="text-4xl font-bold mb-3"><%= t("home.title") %></h1>
        <p class="text-base-content/60 text-lg"><%= t("home.description") %></p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <%= link_to new_compress_path, class: "card bg-base-100 shadow-sm hover:shadow-md transition-shadow" do %>
        <div class="card-body">
            <div class="flex items-center gap-4">
                <div class="p-3 bg-primary/10 rounded-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                    </svg>
                </div>
                <div>
                    <h2 class="card-title text-lg"><%= t("nav.compress") %></h2>
                    <p class="text-base-content/60 text-sm"><%= t("home.compress_desc") %></p>
                </div>
            </div>
        </div>
        <% end %>

        <%= link_to new_resize_path, class: "card bg-base-100 shadow-sm hover:shadow-md transition-shadow" do %>
        <div class="card-body">
            <div class="flex items-center gap-4">
                <div class="p-3 bg-primary/10 rounded-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                    </svg>
                </div>
                <div>
                    <h2 class="card-title text-lg"><%= t("nav.resize") %></h2>
                    <p class="text-base-content/60 text-sm"><%= t("home.resize_desc") %></p>
                </div>
            </div>
        </div>
        <% end %>

        <%= link_to new_rotate_path, class: "card bg-base-100 shadow-sm hover:shadow-md transition-shadow" do %>
        <div class="card-body">
            <div class="flex items-center gap-4">
                <div class="p-3 bg-primary/10 rounded-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                </div>
                <div>
                    <h2 class="card-title text-lg"><%= t("nav.rotate") %></h2>
                    <p class="text-base-content/60 text-sm"><%= t("home.rotate_desc") %></p>
                </div>
            </div>
        </div>
        <% end %>

        <%= link_to new_exif_path, class: "card bg-base-100 shadow-sm hover:shadow-md transition-shadow" do %>
        <div class="card-body">
            <div class="flex items-center gap-4">
                <div class="p-3 bg-primary/10 rounded-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="card-title text-lg"><%= t("nav.exif") %></h2>
                    <p class="text-base-content/60 text-sm"><%= t("home.exif_desc") %></p>
                </div>
            </div>
        </div>
        <% end %>

        <%= link_to new_convert_path, class: "card bg-base-100 shadow-sm hover:shadow-md transition-shadow" do %>
        <div class="card-body">
            <div class="flex items-center gap-4">
                <div class="p-3 bg-primary/10 rounded-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                    </svg>
                </div>
                <div>
                    <h2 class="card-title text-lg"><%= t("nav.convert") %></h2>
                    <p class="text-base-content/60 text-sm"><%= t("home.convert_desc") %></p>
                </div>
            </div>
        </div>
        <% end %>
    </div>
</div>
