<% content_for :title, "My Page — Allimgtools" %>

<div class="max-w-lg mx-auto px-4 py-12 space-y-4">

  <%# Profile card %>
  <div class="bg-base-100 rounded-2xl border border-base-200 p-6">
    <h2 class="text-xs font-semibold text-base-content/40 uppercase tracking-wide mb-5">Profile</h2>

    <div class="mb-6">
      <p class="font-semibold text-base-content"><%= Current.user.name %></p>
      <p class="text-sm text-base-content/50 mt-0.5"><%= Current.user.email_address %></p>
    </div>

    <div class="border-t border-base-200 pt-4">
      <p class="text-xs text-base-content/40 mb-2">Connected account</p>
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span class="text-sm text-base-content/70">Google</span>
        <span class="badge badge-ghost badge-sm ml-1">Connected</span>
      </div>
    </div>
  </div>

  <%# Account card %>
  <div class="bg-base-100 rounded-2xl border border-base-200 p-6">
    <h2 class="text-xs font-semibold text-base-content/40 uppercase tracking-wide mb-5">Account</h2>

    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-base-content/40">Member since</p>
        <p class="text-sm font-medium text-base-content mt-0.5">
          <%= Current.user.created_at.strftime("%B %d, %Y") %>
        </p>
      </div>
    </div>

    <div class="border-t border-base-200 mt-6 pt-5">
      <button onclick="document.getElementById('delete_modal').showModal()"
              class="text-xs text-base-content/30 hover:text-error transition-colors">
        Delete account
      </button>
    </div>
  </div>

</div>

<%# Confirmation modal %>
<dialog id="delete_modal" class="modal">
  <div class="modal-box max-w-sm">
    <h3 class="font-bold text-lg mb-2">Delete account?</h3>
    <p class="text-sm text-base-content/60 leading-relaxed mb-1">
      Your account and all associated data will be permanently removed from Allimgtools.
    </p>
    <div class="flex gap-2 justify-end">
      <form method="dialog">
        <button class="btn btn-ghost btn-sm">Cancel</button>
      </form>
      <%= button_to "Delete account", destroy_account_path, method: :delete,
            class: "btn btn-error btn-sm" %>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
