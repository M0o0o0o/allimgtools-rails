<% content_for :title, t("my_page.title") %>
<% unless Current.user.subscribed? %>
  <% content_for :head do %>
    <script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
  <% end %>
<% end %>

<div class="max-w-lg mx-auto px-4 py-12 space-y-4"
     <% unless Current.user.subscribed? %>
       data-controller="paddle"
       data-paddle-client-token-value="<%= Rails.application.credentials.paddle[:client_token] %>"
       data-paddle-price-id-value="<%= Rails.application.credentials.paddle[:pro_price_id] %>"
       data-paddle-email-value="<%= Current.user.email_address %>"
       data-paddle-checkout-complete-url-value="<%= subscription_checkout_complete_path %>"
       data-paddle-sandbox-value="<%= Rails.application.credentials.paddle[:sandbox] %>"
     <% end %>>

  <%# Upgrade banner (free users only) %>
  <% unless Current.user.subscribed? %>
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-5 shadow-md">
      <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10"></div>
      <div class="absolute -right-2 bottom-0 h-16 w-16 rounded-full bg-white/5"></div>
      <div class="relative flex items-center justify-between gap-4">
        <div>
          <p class="font-bold text-white text-sm"><%= t("my_page.upgrade_banner.title") %></p>
          <p class="text-xs text-white/70 mt-0.5">30 files · 30MB per file</p>
        </div>
        <button class="btn btn-sm bg-white text-primary hover:bg-white/90 border-0 shrink-0 font-semibold shadow-sm"
                data-action="click->paddle#openCheckout">
          <%= t("my_page.upgrade_banner.button") %>
        </button>
      </div>
    </div>
    <div class="text-center -mt-2">
      <%= button_to t("my_page.verify_subscription"), subscription_sync_path,
            method: :post,
            class: "text-xs text-base-content/30 hover:text-primary transition-colors bg-transparent border-none cursor-pointer" %>
    </div>
  <% end %>

  <%# Profile card %>
  <div class="bg-base-100 rounded-2xl border border-base-200 overflow-hidden shadow-sm">

    <%# Card header strip %>
    <% if Current.user.subscribed? %>
      <div class="h-2 bg-gradient-to-r from-primary to-primary/50"></div>
    <% else %>
      <div class="h-2 bg-gradient-to-r from-base-300 to-base-200"></div>
    <% end %>

    <div class="p-6">
      <div class="flex items-start justify-between mb-6">
        <h2 class="text-xs font-semibold text-base-content/40 uppercase tracking-wide"><%= t("my_page.profile.heading") %></h2>
        <% if Current.user.subscribed? %>
          <span class="badge badge-primary badge-sm font-semibold px-2.5"><%= t("my_page.profile.plan_pro") %></span>
        <% else %>
          <span class="badge badge-ghost badge-sm"><%= t("my_page.profile.plan_free") %></span>
        <% end %>
      </div>

      <%# Name / Email %>
      <div class="mb-6">
        <p class="font-bold text-base-content text-lg leading-tight"><%= Current.user.name %></p>
        <p class="text-sm text-base-content/40 mt-1"><%= Current.user.email_address %></p>
      </div>

      <%# Renews row (Pro only) %>
      <% if Current.user.subscribed? %>
        <div class="bg-primary/5 border border-primary/15 rounded-xl px-4 py-3 mb-4 flex items-center justify-between text-sm">
          <div class="flex items-center gap-2 text-base-content/60">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <span><%= t("my_page.profile.renews") %></span>
          </div>
          <span class="font-semibold text-base-content"><%= Current.user.subscribed_until.strftime("%b %d, %Y") %></span>
        </div>
        <%= link_to subscription_portal_path, class: "flex items-center justify-center gap-2 w-full rounded-xl border border-base-200 py-2.5 text-sm text-base-content/50 hover:text-base-content hover:border-base-300 hover:bg-base-50 transition-all mb-4" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
          <%= t("my_page.profile.manage_billing") %>
        <% end %>
      <% end %>

      <%# Connected account %>
      <div class="border-t border-base-200 pt-4">
        <p class="text-xs text-base-content/35 mb-3"><%= t("my_page.profile.connected_account") %></p>
        <div class="flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg border border-base-200 bg-base-50">
            <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-base-content leading-none">Google</p>
            <p class="text-xs text-base-content/40 mt-0.5"><%= Current.user.email_address %></p>
          </div>
          <span class="ml-auto badge badge-success badge-sm text-success-content gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="12" r="6"/>
            </svg>
            <%= t("my_page.profile.connected") %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <%# Account card %>
  <div class="bg-base-100 rounded-2xl border border-base-200 shadow-sm">
    <div class="p-6">
      <h2 class="text-xs font-semibold text-base-content/40 uppercase tracking-wide mb-6"><%= t("my_page.account.heading") %></h2>

      <div class="flex items-center gap-3">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-base-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs text-base-content/40"><%= t("my_page.account.member_since") %></p>
          <p class="text-sm font-semibold text-base-content mt-0.5"><%= Current.user.created_at.strftime("%B %d, %Y") %></p>
        </div>
      </div>
    </div>

    <div class="border-t border-base-200 px-6 py-4 flex items-center justify-between">
      <p class="text-xs text-base-content/30">Allimgtools account</p>
      <button onclick="document.getElementById('delete_modal').showModal()"
              class="text-xs text-base-content/30 hover:text-error transition-colors flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        <%= t("my_page.account.delete_account") %>
      </button>
    </div>
  </div>

</div>

<%# Confirmation modal %>
<dialog id="delete_modal" class="modal">
  <div class="modal-box max-w-sm">
    <h3 class="font-bold text-lg mb-2"><%= t("my_page.delete_modal.title") %></h3>
    <p class="text-sm text-base-content/60 leading-relaxed mb-1">
      <%= t("my_page.delete_modal.description") %>
    </p>
    <div class="flex gap-2 justify-end">
      <form method="dialog">
        <button class="btn btn-ghost btn-sm"><%= t("my_page.delete_modal.cancel") %></button>
      </form>
      <%= button_to t("my_page.delete_modal.confirm"), destroy_account_path, method: :delete,
            class: "btn btn-error btn-sm" %>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
