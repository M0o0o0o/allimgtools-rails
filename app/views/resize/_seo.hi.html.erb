<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        ऑनलाइन इमेज का आकार बदलें —<br class="hidden sm:block"> मुफ्त, तुरंत और गुणवत्ता में कोई कमी नहीं
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        अपनी इमेज के आयाम तुरंत बदलें — किसी सॉफ्टवेयर या साइन-अप की आवश्यकता नहीं। हमारा मुफ्त ऑनलाइन इमेज रिसाइज़र आपको पिक्सेल में सटीक चौड़ाई और ऊंचाई सेट करने, प्रतिशत के अनुसार स्केल करने, या विकृति से बचने के लिए पहलू अनुपात को लॉक करने देता है। JPEG, PNG, WebP, GIF और AVIF के साथ काम करता है। चाहे आप सोशल मीडिया के लिए तस्वीरें तैयार कर रहे हों, अपनी ऑनलाइन दुकान के लिए उत्पाद इमेज का आकार बदल रहे हों, या ब्लॉग के लिए थंबनेल क्रॉप कर रहे हों, आपको कुछ ही सेकंड में पूरी तरह से आकार की इमेज मिल जाएंगी।
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/resize_hero.png", alt: "ऑनलाइन इमेज रिसाइज़र — JPEG, PNG, WebP को तुरंत सटीक पिक्सेल आयामों में बदलें", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">चरण-दर-चरण</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ऑनलाइन इमेज का आकार कैसे बदलें</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">अपनी इमेज अपलोड करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">JPEG, JPG, PNG, GIF, WebP, या AVIF फ़ाइल चुनने के लिए ड्रैग और ड्रॉप करें या क्लिक करें।</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">अपने लक्ष्य आयाम सेट करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">पिक्सेल में चौड़ाई और ऊंचाई दर्ज करें, या प्रतिशत के अनुसार स्केल करें। खिंचाव से बचने के लिए "पहलू अनुपात बनाए रखें" टॉगल करें।</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">अपनी आकार बदली हुई इमेज डाउनलोड करें</p>
            <p class="text-sm text-base-content/55 leading-relaxed">डाउनलोड पर क्लिक करें और अपनी पूरी तरह से आकार वाली फ़ाइल को तुरंत सहेजें।</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        किसी खाते की आवश्यकता नहीं। आपकी फ़ाइलें हमारे सर्वर पर कभी संग्रहीत नहीं होती हैं।
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">फ़ॉर्मेट</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">JPEG, PNG, WebP और अन्य का आकार बदलें</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "तस्वीरों के लिए सबसे सामान्य फ़ॉर्मेट। प्राकृतिक रंगों और ग्रेडिएंट को बनाए रखते हुए उच्च-रिज़ॉल्यूशन वाली इमेज का आकार बदलें।" },
          { name: "PNG",        desc: "पारदर्शिता का समर्थन करता है। अल्फा चैनल खोए बिना लोगो, स्क्रीनशॉट और ग्राफिक्स का आकार बदलें।" },
          { name: "GIF",        desc: "स्थिर GIF का आकार आसानी से बदलें। एनिमेटेड GIF का आकार बदलने पर सभी फ्रेम बरकरार रहते हैं।" },
          { name: "WebP",       desc: "गूगल का आधुनिक फ़ॉर्मेट। WebP इमेज का आकार बदलें और फ़ाइल आकार को कॉम्पैक्ट रखें।" },
          { name: "AVIF",       desc: "छोटे फ़ाइल आकार पर उत्कृष्ट गुणवत्ता वाला अगली पीढ़ी का फ़ॉर्मेट। पूर्ण आकार बदलने का समर्थन।" },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Social media dimensions table ─────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">संदर्भ</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">सोशल मीडिया के लिए सामान्य इमेज आयाम</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        हर प्लेटफॉर्म का अपना अनुशंसित इमेज आकार होता है। अपनी इमेज को आवश्यक सटीक आयामों में बदलने के लिए इस संदर्भ तालिका का उपयोग करें:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">प्लेटफ़ॉर्म / उपयोग</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">अनुशंसित आकार</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["इंस्टाग्राम पोस्ट (वर्ग)",  "1080 × 1080 px"],
              ["फेसबुक कवर फोटो",     "820 × 312 px"],
              ["ट्विटर / एक्स हेडर",       "1500 × 500 px"],
              ["लिंक्डइन बैनर",          "1584 × 396 px"],
              ["यूट्यूब थंबनेल",        "1280 × 720 px"],
            ].each do |platform, size| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= platform %></td>
                <td class="text-sm text-base-content/60"><%= size %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">प्लेटफ़ॉर्म दिशानिर्देश समय के साथ बदलते रहते हैं। प्रकाशित करने से पहले हमेशा नवीनतम आधिकारिक दस्तावेज़ों से सत्यापित करें।</p>
    </div>

    <%# ── Web / E-commerce use case ─────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">वेब और ई-कॉमर्स</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">उत्पाद फ़ोटो और वेब इमेज का आकार बदलें</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        लगातार इमेज आयाम आपकी वेबसाइट को आकर्षक और तेज़ी से लोड होने वाला बनाते हैं। अपनी साइट या स्टोर पर अपलोड करने से पहले, इमेज का आकार बदलें ताकि:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["अपने लेआउट से बिल्कुल मेल खाएं",       "एक सटीक पिक्सेल चौड़ाई सेट करें ताकि इमेज बिना CSS विकृति के आपकी ग्रिड में फिट हो सकें।"],
          ["पेज लोड को तेज़ करें",             "छोटे आयामों का मतलब है छोटे फ़ाइल आकार, जिससे बैंडविड्थ कम होती है और कोर वेब वाइटल्स में सुधार होता है।"],
          ["उत्पाद थंबनेल को मानकीकृत करें",  "उत्पाद ग्रिड में समान आकार पेशेवर दिखते हैं और लेआउट शिफ्ट को कम करते हैं।"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200">
        <strong class="text-base-content font-semibold">ई-कॉमर्स टिप:</strong> अपने स्टोर पर अपलोड करने से पहले सभी उत्पाद इमेज का आकार समान आयामों में बदलें। अधिकांश प्लेटफ़ॉर्म (Shopify, WooCommerce, Etsy) ज़ूम कार्यक्षमता के लिए 1000 × 1000 पिक्सेल या उससे बड़े वर्ग इमेज की सलाह देते हैं।
      </div>
    </div>

    <%# ── Bulk resize ────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">प्रो सुविधा</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">एक साथ कई इमेज का आकार बदलना</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        एक साथ कई इमेज का आकार समान आयामों में बदलने की आवश्यकता है? हमारा बल्क रिसाइज़ टूल आपको एक बार में कई फ़ाइलें अपलोड और प्रोसेस करने देता है — इसके लिए एकदम सही है:
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["उत्पाद कैटलॉग",  "अपने स्टोर पर अपलोड करने से पहले सैकड़ों उत्पाद फ़ोटो को मानकीकृत करें।"],
          ["फोटो गैलरी",   "एक ही बैच में पूरे शूट का आकार सुसंगत आयामों में बदलें।"],
          ["सोशल मीडिया सेट", "प्रक्रिया को दोहराए बिना कई इमेज को प्लेटफ़ॉर्म विनिर्देशों के अनुसार तैयार करें।"],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= label %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-6 flex items-center justify-between gap-6">
        <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 pointer-events-none"></div>
        <div class="absolute right-8 bottom-0 h-14 w-14 rounded-full bg-white/5 pointer-events-none"></div>
        <div class="relative">
          <p class="font-bold text-white mb-0.5">बल्क प्रोसेसिंग प्रो पर उपलब्ध है</p>
          <p class="text-white/60 text-sm">एक क्लिक में कई फ़ाइलों का आकार समान आयामों में बदलें।</p>
        </div>
        <%= link_to pricing_path, class: "relative shrink-0 btn btn-sm bg-white text-primary hover:bg-white/90 border-0 font-semibold shadow-sm" do %>
          मुफ्त में शुरू करें →
        <% end %>
      </div>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">उपयोग के मामले</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">इमेज का आकार क्यों बदलें?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["सोशल मीडिया",       "हर प्लेटफॉर्म की सख्त आकार आवश्यकताएं होती हैं। प्लेटफॉर्म द्वारा क्रॉपिंग, लेटरबॉक्सिंग या धुंधले अपस्केलिंग से बचने के लिए सही आयामों में आकार बदलें।"],
          ["ई-कॉमर्स स्टोर",  "उत्पाद इमेज की निरंतरता विश्वास बनाती है। आपके कैटलॉग में समान आयाम किसी भी डिवाइस पर एक पेशेवर ग्रिड लेआउट बनाते हैं।"],
          ["ईमेल न्यूज़लेटर",  "चौड़ी इमेज मोबाइल पर ईमेल लेआउट को तोड़ सकती हैं। सभी ईमेल क्लाइंट में विश्वसनीय रेंडरिंग के लिए हेडर इमेज का आकार 600 पिक्सेल चौड़ा करें।"],
          ["प्रिंट और दस्तावेज़",  "निर्यात पर गुणवत्ता हानि से बचने के लिए अपनी प्रिंट टेम्पलेट, प्रस्तुति या दस्तावेज़ लेआउट द्वारा आवश्यक सटीक पिक्सेल आयामों में इमेज का आकार बदलें।"],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">अक्सर पूछे जाने वाले प्रश्न</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">अक्सर पूछे जाने वाले प्रश्न</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["आकार बदलते समय मैं पहलू अनुपात कैसे बनाए रखूं?",
           "अपने आयाम दर्ज करने से पहले 'पहलू अनुपात बनाए रखें' टॉगल को सक्षम करें। सक्रिय होने पर, चौड़ाई दर्ज करने से स्वचालित
