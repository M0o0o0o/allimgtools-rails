<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        Afbeeldingen Online Vergroten/Verkleinen —<br class="hidden sm:block"> Gratis, Direct &amp; Zonder Kwaliteitsverlies
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        Wijzig de afmetingen van uw afbeeldingen direct — geen software, geen aanmelding vereist. Onze gratis online afbeeldingsresizer laat u een exacte breedte en hoogte in pixels instellen, schalen op percentage, of de beeldverhouding vergrendelen om vervorming te voorkomen. Werkt met JPEG, PNG, WebP, GIF en AVIF. Of u nu foto's voorbereidt voor sociale media, productafbeeldingen voor uw online winkel verkleint, of miniaturen voor een blog bijsnijdt, u krijgt binnen enkele seconden perfect formaat afbeeldingen.
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/resize_hero.png", alt: "Online afbeeldingsresizer — verklein/vergroot JPEG, PNG, WebP direct naar exacte pixelafmetingen", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Stap voor stap</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Hoe u een Afbeelding Online Verkleint/Vergroot</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Upload uw afbeelding</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Sleep en plaats of klik om een JPEG-, JPG-, PNG-, GIF-, WebP- of AVIF-bestand te selecteren.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Stel uw gewenste afmetingen in</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Voer een breedte en hoogte in pixels in, of schaal op percentage. Schakel 'Beeldverhouding behouden' in om uitrekken te voorkomen.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Download uw verkleinde/vergrote afbeelding</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Klik op downloaden en sla uw perfect formaat bestand direct op.</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Geen account vereist. Uw bestanden worden nooit op onze servers opgeslagen.
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Formaten</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Verklein/Vergroot JPEG, PNG, WebP &amp; Meer</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "Het meest voorkomende formaat voor foto's. Verklein/vergroot afbeeldingen met hoge resolutie met behoud van natuurlijke kleuren en verlopen." },
          { name: "PNG",        desc: "Ondersteunt transparantie. Verklein/vergroot logo's, screenshots en afbeeldingen zonder het alfakanaal te verliezen." },
          { name: "GIF",        desc: "Verklein/vergroot statische GIF's met gemak. Het vergroten/verkleinen van geanimeerde GIF's behoudt alle frames." },
          { name: "WebP",       desc: "Google's moderne formaat. Verklein/vergroot WebP-afbeeldingen en houd bestandsgroottes compact." },
          { name: "AVIF",       desc: "Volgende-generatie formaat met uitstekende kwaliteit bij kleine bestandsgroottes. Volledige ondersteuning voor vergroten/verkleinen." },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Social media dimensions table ─────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Referentie</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Veelvoorkomende Afbeeldingsafmetingen voor Sociale Media</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Elk platform heeft zijn eigen aanbevolen afbeeldingsgrootte. Gebruik deze referentietabel om uw afbeeldingen te verkleinen/vergroten naar de exacte afmetingen die u nodig heeft:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">Platform / Gebruik</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">Aanbevolen Grootte</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["Instagram Bericht (vierkant)",  "1080 × 1080 px"],
              ["Facebook Omslagfoto",     "820 × 312 px"],
              ["Twitter / X Header",       "1500 × 500 px"],
              ["LinkedIn Banner",          "1584 × 396 px"],
              ["YouTube Miniatuur",        "1280 × 720 px"],
            ].each do |platform, size| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= platform %></td>
                <td class="text-sm text-base-content/60"><%= size %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">Platformrichtlijnen veranderen na verloop van tijd. Controleer altijd de nieuwste officiële documentatie voordat u publiceert.</p>
    </div>

    <%# ── Web / E-commerce use case ─────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Web & E-commerce</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Verklein/Vergroot Productfoto's &amp; Webafbeeldingen</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Consistente afbeeldingsafmetingen zorgen ervoor dat uw website er verzorgd uitziet en sneller laadt. Voordat u uploadt naar uw site of winkel, verklein/vergroot afbeeldingen naar:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["Precies overeenkomen met uw lay-out",       "Stel een precieze pixelbreedte in zodat afbeeldingen in uw raster passen zonder CSS-vervorming."],
          ["Versnel het laden van pagina's",             "Kleinere afmetingen betekenen kleinere bestandsgroottes, wat de bandbreedte vermindert en de Core Web Vitals verbetert."],
          ["Standaardiseer productminiaturen",  "Uniforme groottes over productrasters zien er professioneel uit en verminderen lay-outverschuivingen."],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200">
        <strong class="text-base-content font-semibold">E-commerce tip:</strong> Verklein/vergroot alle productafbeeldingen naar dezelfde afmetingen voordat u ze naar uw winkel uploadt. De meeste platforms (Shopify, WooCommerce, Etsy) bevelen vierkante afbeeldingen aan van 1000 × 1000 px of groter voor zoomfunctionaliteit.
      </div>
    </div>

    <%# ── Bulk resize ────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Pro-functie</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Bulk Afbeeldingen Vergroten/Verkleinen</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Moet u meerdere afbeeldingen tegelijk naar dezelfde afmetingen verkleinen/vergroten? Onze bulk-resizer tool laat u meerdere bestanden in één keer uploaden en verwerken — perfect voor:
      </p>
      <ul class="space-y-3 mb-8">
        <% [
          ["Productcatalogi",  "Standaardiseer honderden productfoto's voordat u ze naar uw winkel uploadt."],
          ["Fotogalerijen",   "Verklein/vergroot een hele fotoshoot naar consistente afmetingen in één batch."],
          ["Sociale media sets", "Bereid meerdere afbeeldingen voor op platforms specificaties zonder het proces te herhalen."],
        ].each do |label, desc| %>
          <li class="flex gap-3 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-base-200 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= label %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary to-primary/70 p-6 flex items-center justify-between gap-6">
        <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 pointer-events-none"></div>
        <div class="absolute right-8 bottom-0 h-14 w-14 rounded-full bg-white/5 pointer-events-none"></div>
        <div class="relative">
          <p class="font-bold text-white mb-0.5">Bulkverwerking is beschikbaar in Pro</p>
          <p class="text-white/60 text-sm">Verklein/vergroot meerdere bestanden naar dezelfde afmetingen met één klik.</p>
        </div>
        <%= link_to pricing_path, class: "relative shrink-0 btn btn-sm bg-white text-primary hover:bg-white/90 border-0 font-semibold shadow-sm" do %>
          Start gratis →
        <% end %>
      </div>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Gebruiksscenario's</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Waarom Afbeeldingen Verkleinen/Vergroten?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["Sociale media",       "Elk platform heeft strikte afmetingsvereisten. Verklein/vergroot naar de juiste afmetingen om bijsnijden, letterboxing of wazige opschaling door het platform te voorkomen."],
          ["E-commerce winkels",  "Consistentie van productafbeeldingen bouwt vertrouwen op. Uniforme afmetingen in uw catalogus creëren een professionele rasterlay-out op elk apparaat."],
          ["E-mailnieuwsbrieven",  "Brede afbeeldingen kunnen e-maillay-outs op mobiel breken. Verklein/vergroot header-afbeeldingen tot 600 px breed voor betrouwbare weergave in alle e-mailclients."],
          ["Print
