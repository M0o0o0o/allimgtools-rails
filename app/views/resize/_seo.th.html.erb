<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        ปรับขนาดรูปภาพออนไลน์ —<br class="hidden sm:block"> ฟรี รวดเร็ว และไม่ลดคุณภาพ
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        เปลี่ยนขนาดรูปภาพของคุณได้ทันที — ไม่ต้องใช้ซอฟต์แวร์ ไม่ต้องลงทะเบียน เครื่องมือปรับขนาดรูปภาพออนไลน์ฟรีของเราช่วยให้คุณกำหนดความกว้างและความสูงที่แน่นอนเป็นพิกเซล ปรับขนาดตามเปอร์เซ็นต์ หรือล็อกอัตราส่วนภาพเพื่อหลีกเลี่ยงการบิดเบือน ใช้งานได้กับ JPEG, PNG, WebP, GIF และ AVIF ไม่ว่าคุณจะเตรียมรูปภาพสำหรับโซเชียลมีเดีย ปรับขนาดรูปภาพสินค้าสำหรับร้านค้าออนไลน์ หรือครอบรูปภาพขนาดย่อสำหรับบล็อก คุณจะได้รูปภาพขนาดที่สมบูรณ์แบบในไม่กี่วินาที
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/resize_hero.png", alt: "เครื่องมือปรับขนาดรูปภาพออนไลน์ — ปรับขนาด JPEG, PNG, WebP ให้ได้ขนาดพิกเซลที่แน่นอนทันที", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ทีละขั้นตอน</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">วิธีปรับขนาดรูปภาพออนไลน์</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">อัปโหลดรูปภาพของคุณ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">ลากและวาง หรือคลิกเพื่อเลือกไฟล์ JPEG, JPG, PNG, GIF, WebP หรือ AVIF</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">กำหนดขนาดที่คุณต้องการ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">ป้อนความกว้างและความสูงเป็นพิกเซล หรือปรับขนาดตามเปอร์เซ็นต์ เปิด/ปิด "รักษาสัดส่วนภาพ" เพื่อป้องกันภาพยืด</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">ดาวน์โหลดรูปภาพที่ปรับขนาดแล้วของคุณ</p>
            <p class="text-sm text-base-content/55 leading-relaxed">คลิกดาวน์โหลดและบันทึกไฟล์ขนาดที่สมบูรณ์แบบของคุณได้ทันที</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        ไม่ต้องมีบัญชี ไฟล์ของคุณจะไม่ถูกจัดเก็บไว้บนเซิร์ฟเวอร์ของเรา
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">รูปแบบไฟล์</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ปรับขนาด JPEG, PNG, WebP และอื่นๆ</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "รูปแบบที่นิยมที่สุดสำหรับภาพถ่าย ปรับขนาดภาพความละเอียดสูงพร้อมรักษาสีและไล่ระดับสีตามธรรมชาติ" },
          { name: "PNG",        desc: "รองรับความโปร่งใส ปรับขนาดโลโก้ ภาพหน้าจอ และกราฟิกโดยไม่สูญเสียช่องอัลฟ่า" },
          { name: "GIF",        desc: "ปรับขนาด GIF แบบคงที่ได้อย่างง่ายดาย การปรับขนาด GIF แบบเคลื่อนไหวจะยังคงรักษาทุกเฟรมไว้" },
          { name: "WebP",       desc: "รูปแบบที่ทันสมัยของ Google ปรับขนาดภาพ WebP และรักษาขนาดไฟล์ให้กะทัดรัด" },
          { name: "AVIF",       desc: "รูปแบบยุคใหม่ที่มีคุณภาพยอดเยี่ยมที่ขนาดไฟล์เล็ก รองรับการปรับขนาดเต็มรูปแบบ" },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Social media dimensions table ─────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">ข้อมูลอ้างอิง</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ขนาดรูปภาพทั่วไปสำหรับโซเชียลมีเดีย</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        แต่ละแพลตฟอร์มมีขนาดรูปภาพที่แนะนำของตัวเอง ใช้ตารางอ้างอิงนี้เพื่อปรับขนาดรูปภาพของคุณให้ได้ขนาดที่ต้องการ:
      </p>
      <div class="overflow-x-auto rounded-2xl border border-base-200">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200/60 border-base-200">
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">แพลตฟอร์ม / การใช้งาน</th>
              <th class="text-xs text-base-content/50 font-semibold uppercase tracking-wide">ขนาดที่แนะนำ</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ["โพสต์ Instagram (สี่เหลี่ยมจัตุรัส)",  "1080 × 1080 px"],
              ["รูปภาพหน้าปก Facebook",     "820 × 312 px"],
              ["ส่วนหัว Twitter / X",       "1500 × 500 px"],
              ["แบนเนอร์ LinkedIn",          "1584 × 396 px"],
              ["ภาพขนาดย่อ YouTube",        "1280 × 720 px"],
            ].each do |platform, size| %>
              <tr class="border-base-200">
                <td class="text-sm font-medium text-base-content"><%= platform %></td>
                <td class="text-sm text-base-content/60"><%= size %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-base-content/35 mt-3">แนวทางของแพลตฟอร์มมีการเปลี่ยนแปลงอยู่เสมอ โปรดตรวจสอบเอกสารทางการล่าสุดก่อนเผยแพร่</p>
    </div>

    <%# ── Web / E-commerce use case ─────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">เว็บและอีคอมเมิร์ซ</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">ปรับขนาดรูปภาพสินค้าและรูปภาพสำหรับเว็บ</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        ขนาดรูปภาพที่สอดคล้องกันทำให้เว็บไซต์ของคุณดูเป็นมืออาชีพและโหลดเร็วขึ้น ก่อนอัปโหลดไปยังเว็บไซต์หรือร้านค้าของคุณ ให้ปรับขนาดรูปภาพเพื่อ:
      </p>
      <ul class="space-y-4 mb-8">
        <% [
          ["ให้เข้ากับเลย์เอาต์ของคุณอย่างแม่นยำ",       "กำหนดความกว้างเป็นพิกเซลที่แม่นยำ เพื่อให้รูปภาพพอดีกับตารางของคุณโดยไม่มีการบิดเบือนจาก CSS"],
          ["เร่งความเร็วในการโหลดหน้าเว็บ",             "ขนาดที่เล็กลงหมายถึงขนาดไฟล์ที่เล็กลง ลดแบนด์วิดท์และปรับปรุง Core Web Vitals"],
          ["สร้างมาตรฐานภาพขนาดย่อของสินค้า",  "ขนาดที่สม่ำเสมอทั่วทั้งตารางสินค้าจะดูเป็นมืออาชีพและลดการเปลี่ยนแปลงเลย์เอาต์"],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200">
        <strong class="text-base-content font-semibold">เคล็ดลับอีคอมเมิร์ซ:</strong> ปรับขนาดรูปภาพสินค้าทั้งหมดให้มีขนาดเท่ากันก่อนอัปโหลดไปยังร้านค้าของคุณ แพลตฟอร์มส่วนใหญ่ (Shopify, WooCommerce, Etsy) แนะนำรูปภาพสี่เหลี่ยมจัตุรัสขนาด 1000 × 1000 px หรือใหญ่กว่าสำหรับฟังก์ชันการซูม
      </div>
    </div>

    <%# ── Bulk resize ────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">คุณสมบัติ Pro</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">การปรับขนาดรูปภาพจำนวนมาก</h2>
      </div>
