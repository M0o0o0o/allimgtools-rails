<% content_for :title, "Free Image Resizer — Resize Images Online | Allimgtools" %>
<% content_for :description, "Resize JPEG, PNG, WebP, GIF, and AVIF images online for free. Set custom dimensions and maintain aspect ratio. No signup required." %>
<% content_for :head do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Image Resizer",
    "url": "https://allimgtools.com/resize",
    "applicationCategory": "MultimediaApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": "Resize JPEG, PNG, WebP, GIF, and AVIF images online for free."
  }
  </script>
<% end %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Image Resize</h1>
    <p class="text-base-content/60 mt-2">Upload images and adjust them to your desired dimensions.</p>
  </div>

  <div class="card bg-base-100 shadow-sm">
    <div class="card-body">
      <%= render "shared/upload_form", success_path: "/resize", task: @task %>
    </div>
  </div>
</div>
