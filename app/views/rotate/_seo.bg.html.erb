<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        Завъртете изображения онлайн —<br class="hidden sm:block"> Безплатно &amp; Незабавно
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        Коригирайте обърнати настрани или с главата надолу снимки незабавно — без софтуер, без регистрация. Нашият безплатен онлайн инструмент за завъртане на изображения ви позволява да завъртите всеки JPEG, PNG, WebP или GIF с 90°, 180° или 270° с едно щракване. Независимо дали коригирате снимка, направена в грешна ориентация, подготвяте изображение за печат или изправяте сканиране, ще получите правилно ориентирания файл за секунди.
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/rotate_hero.png", alt: "Онлайн инструмент за завъртане на изображения — завъртете JPEG, PNG, WebP с 90°, 180° или 270° незабавно", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Стъпка по стъпка</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Как да завъртите изображение онлайн</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Качете вашето изображение</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Плъзнете и пуснете или щракнете, за да изберете JPEG, JPG, PNG, GIF или WebP файл.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Изберете вашето завъртане</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Изберете 90° по часовниковата стрелка, 90° обратно на часовниковата стрелка или 180°, за да обърнете с главата надолу. Прегледът се актуализира незабавно.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Изтеглете вашето завъртяно изображение</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Щракнете върху изтегляне и запазете правилно ориентирания си файл незабавно.</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Не е необходим акаунт. Вашите файлове никога не се съхраняват на нашите сървъри.
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Формати</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Завъртете JPEG, PNG, WebP &amp; Още</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "Най-често срещаният фото формат. Завъртете без повторно кодиране, за да запазите качеството, където е възможно." },
          { name: "PNG",        desc: "Поддържа прозрачност. Завъртането запазва алфа канала — логата и графиките остават непокътнати." },
          { name: "GIF",        desc: "Завъртете статични GIF файлове чисто. Анимираните GIF файлове се завъртат кадър по кадър." },
          { name: "WebP",       desc: "Модерният формат на Google. Пълна поддръжка за завъртане без загуба на качество." },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Common use cases ───────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Кога да го използвате</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Чести причини за завъртане на изображение</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Проблемите с ориентацията са по-чести, отколкото си мислите. Ето ситуациите, при които завъртането на изображение е най-бързото решение:
      </p>
      <ul class="space-y-4">
        <% [
          ["Коригиране на ориентацията на камерата",       "Смартфоните и камерите понякога запазват снимки настрани, когато са направени в пейзажен или портретен режим. Бързо завъртане на 90° го коригира без загуба на качество."],
          ["Коригиране на сканирани документи",    "Скенерите често произвеждат завъртян изход в зависимост от това как е поставен оригиналът. Завъртете сканирането си до правилната ориентация за четене, преди да го споделите или архивирате."],
          ["Подготовка на изображения за печат",     "Печатните оформления изискват изображения в специфична ориентация. Завъртете преди експортиране, за да избегнете изненади при принтера."],
          ["Изправяне на съдържание за социални мрежи","Качването на странична снимка в Instagram или блог изглежда непрофесионално. Завъртете преди качване, за да не се завърти платформата автоматично неочаквано."],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-
