<section class="border-t border-base-200">
  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 space-y-20">

    <%# ── Hero ──────────────────────────────────────────────────────── %>
    <div class="space-y-5">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-base-content leading-tight">
        Xoay ảnh trực tuyến —<br class="hidden sm:block"> Miễn phí &amp; Tức thì
      </h1>
      <p class="text-base-content/55 leading-relaxed text-base sm:text-lg max-w-2xl">
        Khắc phục ảnh bị nghiêng hoặc lộn ngược ngay lập tức — không cần phần mềm, không cần đăng ký. Công cụ xoay ảnh trực tuyến miễn phí của chúng tôi cho phép bạn xoay bất kỳ tệp JPEG, PNG, WebP hoặc GIF nào 90°, 180° hoặc 270° chỉ với một cú nhấp chuột. Cho dù bạn đang chỉnh sửa một bức ảnh chụp sai hướng, chuẩn bị hình ảnh để in hay làm thẳng một bản quét, bạn sẽ nhận được tệp đã được định hướng đúng trong vài giây.
      </p>
      <div class="rounded-2xl overflow-hidden border border-base-200 shadow-sm mt-4">
        <%= image_tag "/images/seo/rotate_hero.png", alt: "Công cụ xoay ảnh trực tuyến — xoay JPEG, PNG, WebP 90°, 180° hoặc 270° ngay lập tức", class: "w-full h-auto object-cover", loading: "lazy", width: "800", height: "450" %>
      </div>
    </div>

    <%# ── How to ─────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Từng bước một</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Cách xoay ảnh trực tuyến</h2>
      </div>
      <ol class="space-y-5">
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">1</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Tải ảnh của bạn lên</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Kéo và thả hoặc nhấp để chọn tệp JPEG, JPG, PNG, GIF hoặc WebP.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">2</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Chọn góc xoay của bạn</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Chọn 90° theo chiều kim đồng hồ, 90° ngược chiều kim đồng hồ hoặc 180° để lật ngược. Xem trước cập nhật tức thì.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary font-extrabold text-sm mt-0.5">3</span>
          <div class="pt-1.5">
            <p class="font-semibold text-base-content mb-1">Tải ảnh đã xoay của bạn xuống</p>
            <p class="text-sm text-base-content/55 leading-relaxed">Nhấp tải xuống và lưu tệp đã được định hướng đúng của bạn ngay lập tức.</p>
          </div>
        </li>
      </ol>
      <p class="text-xs text-base-content/35 mt-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Không yêu cầu tài khoản. Tệp của bạn không bao giờ được lưu trữ trên máy chủ của chúng tôi.
      </p>
    </div>

    <%# ── Supported formats ──────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Định dạng</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Xoay JPEG, PNG, WebP &amp; Nhiều hơn nữa</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% [
          { name: "JPEG / JPG", desc: "Định dạng ảnh phổ biến nhất. Xoay mà không cần mã hóa lại để giữ nguyên chất lượng nếu có thể." },
          { name: "PNG",        desc: "Hỗ trợ độ trong suốt. Xoay giữ nguyên kênh alpha — logo và đồ họa vẫn nguyên vẹn." },
          { name: "GIF",        desc: "Xoay GIF tĩnh một cách rõ ràng. GIF động được xoay từng khung hình." },
          { name: "WebP",       desc: "Định dạng hiện đại của Google. Hỗ trợ xoay hoàn toàn mà không giảm chất lượng." },
        ].each do |fmt| %>
          <div class="bg-base-200/40 border border-base-200 rounded-xl p-4 hover:border-primary/30 hover:bg-primary/3 transition-colors">
            <p class="font-semibold text-base-content text-sm mb-1.5"><%= fmt[:name] %></p>
            <p class="text-xs text-base-content/55 leading-relaxed"><%= fmt[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Common use cases ───────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Khi nào nên sử dụng</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Những lý do phổ biến để xoay ảnh</h2>
      </div>
      <p class="text-base-content/55 mb-6 text-sm leading-relaxed">
        Các vấn đề về hướng ảnh phổ biến hơn bạn nghĩ. Dưới đây là những tình huống mà việc xoay ảnh là cách khắc phục nhanh nhất:
      </p>
      <ul class="space-y-4">
        <% [
          ["Sửa hướng ảnh từ máy ảnh",       "Điện thoại thông minh và máy ảnh đôi khi lưu ảnh bị nghiêng khi chụp ở chế độ ngang hoặc dọc. Một lần xoay 90° nhanh chóng sẽ khắc phục mà không làm giảm chất lượng."],
          ["Chỉnh sửa tài liệu đã quét",    "Máy quét thường tạo ra đầu ra bị xoay tùy thuộc vào cách đặt bản gốc. Xoay bản quét của bạn về hướng đọc đúng trước khi chia sẻ hoặc lưu trữ."],
          ["Chuẩn bị ảnh để in",     "Bố cục in yêu cầu ảnh ở một hướng cụ thể. Xoay trước khi xuất để tránh bất ngờ khi in."],
          ["Chỉnh thẳng nội dung cho mạng xã hội","Tải ảnh bị nghiêng lên Instagram hoặc blog trông không chuyên nghiệp. Xoay trước khi tải lên để nền tảng không tự động xoay ngoài ý muốn."],
        ].each do |title, desc| %>
          <li class="flex gap-4 items-start">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/15 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            <p class="text-sm text-base-content/70"><strong class="text-base-content font-semibold"><%= title %></strong> — <%= desc %></p>
          </li>
        <% end %>
      </ul>
      <div class="bg-base-200/50 rounded-xl px-5 py-4 text-sm text-base-content/55 leading-relaxed border border-base-200 mt-8">
        <strong class="text-base-content font-semibold">Bạn có biết không?</strong> Tệp JPEG lưu trữ siêu dữ liệu hướng (dữ liệu EXIF) riêng biệt với dữ liệu pixel thực tế. Một số ứng dụng hiển thị hình ảnh chính xác bằng cách sử dụng siêu dữ liệu này, trong khi những ứng dụng khác bỏ qua và hiển thị hướng thô. Xoay các pixel thực tế (như công cụ này thực hiện) đảm bảo hình ảnh hiển thị chính xác ở mọi nơi.
      </div>
    </div>

    <%# ── Use cases ──────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Trường hợp sử dụng</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Ai sử dụng công cụ xoay ảnh?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% [
          ["Nhiếp ảnh gia",      "Sửa hướng cho một loạt ảnh sau buổi chụp. Hướng nhất quán trên toàn bộ album giúp các bộ sưu tập trông bóng bẩy và chuyên nghiệp."],
          ["Blogger & nhà văn", "Ảnh chụp sai hướng làm phá vỡ bố cục trực quan của bài viết. Xoay trước khi tải lên CMS của bạn để đảm bảo hình ảnh hiển thị chính xác cho tất cả độc giả."],
          ["Người bán hàng thương mại điện tử", "Ảnh sản phẩm chụp bị nghiêng trông không đáng tin cậy. Chỉnh sửa hướng trước khi tải lên cửa hàng của bạn để trình bày sản phẩm rõ ràng."],
          ["Văn phòng & tài liệu", "Hợp đồng, hóa đơn hoặc tài liệu ID đã quét thường bị xoay. Sửa hướng trước khi đính kèm vào email hoặc tải lên hệ thống quản lý tài liệu."],
        ].each do |title, desc| %>
          <div class="rounded-2xl border border-base-200 bg-base-100 p-6 hover:border-primary/20 hover:shadow-sm transition-all">
            <p class="font-semibold text-base-content mb-2"><%= title %></p>
            <p class="text-sm text-base-content/55 leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── FAQ ───────────────────────────────────────────────────────── %>
    <div>
      <div class="mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">Câu hỏi thường gặp</span>
        <h2 class="text-2xl sm:text-3xl font-bold text-base-content mt-2">Các câu hỏi thường gặp</h2>
      </div>
      <div class="space-y-2">
        <% [
          ["Việc xoay ảnh có làm giảm chất lượng không?",
           "Đối với hầu hết các định dạng, không. Xoay chính xác 90°, 180° hoặc 270° là một thao tác không mất dữ liệu đối với PNG và WebP. Đối với JPEG, hình ảnh được lưu lại sau khi xoay, có thể liên quan đến một bước giảm chất lượng rất nhỏ nếu công cụ mã hóa lại — nhưng ở cài đặt chất lượng cao thì điều này không thể nhận thấy."],
          ["Công cụ xoay ảnh hỗ trợ những định dạng ảnh nào?",
           "Công cụ hỗ trợ JPEG, JPG, PNG, GIF và WebP. Định dạng đầu ra khớp với tệp đầu vào của bạn, vì vậy PNG vẫn là PNG (với độ trong suốt nguyên vẹn) sau khi xoay."],
          ["Làm cách nào để sửa ảnh bị lộn ngược?",
           "Tải ảnh của bạn lên và chọn tùy chọn xoay 180°. Thao tác này sẽ lật hoàn toàn hình ảnh, sửa bất kỳ hướng bị lộn ngược nào chỉ bằng một cú nhấp chuột."],
          ["Sự khác biệt giữa tự động xoay và xoay thủ công là gì?",
           "Tự động xoay sử dụng siêu dữ liệu hướng EXIF được nhúng bởi máy ảnh hoặc điện thoại của bạn để hiển thị hình ảnh chính xác. Xoay thủ công thay đổi vật lý dữ liệu pixel. Nếu bạn thấy hình ảnh hiển thị bị nghiêng trong một số ứng dụng (bỏ qua EXIF), hãy sử dụng công cụ này để tự động nhúng hướng chính xác vào chính tệp."],
          ["Ảnh đã xoay của tôi có giữ nguyên định dạng tệp và độ trong suốt không?",
           "Có. Định dạng đầu ra khớp với đầu vào của bạn. Tệp PNG giữ nguyên độ trong suốt (kênh alpha) sau khi xoay. Không có chuyển đổi nào xảy ra trừ khi bạn chọn một định dạng khác một cách rõ ràng."],
        ].each do |question, answer| %>
          <div class="collapse collapse-plus rounded-xl border border-base-200 bg-base-100 hover:border-primary/20 transition-colors">
            <input type="checkbox">
            <div class="collapse-title font-semibold text-base-content text-sm"><%= question %></div>
            <div class="collapse-content">
              <p class="text-sm text-base-content/60 leading-relaxed"><%= answer %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Footer note ─────────────────────────────────────────────────── %>
    <p class="text-xs text-base-content/25 text-right">Cập nhật lần cuối: Tháng 5 năm 2026</p>

  </div>
</section>
