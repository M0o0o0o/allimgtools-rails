<div class="flex items-center justify-center min-h-[60vh]">
  <div class="card bg-base-100 shadow w-full max-w-sm">
    <div class="card-body">
      <h1 class="card-title text-2xl mb-2">Admin Sign in</h1>

      <%= form_with url: session_path do |form| %>
        <div class="form-control mb-4">
          <%= form.label :email_address, "Email", class: "label" %>
          <%= form.email_field :email_address, required: true, autofocus: true,
              autocomplete: "username", value: params[:email_address],
              class: "input input-bordered w-full" %>
        </div>

        <div class="form-control mb-6">
          <%= form.label :password, "Password", class: "label" %>
          <%= form.password_field :password, required: true,
              autocomplete: "current-password", maxlength: 72,
              class: "input input-bordered w-full" %>
        </div>

        <%= form.submit "Sign in", class: "btn btn-primary w-full" %>
      <% end %>

      <div class="text-center mt-3">
        <%= link_to "Forgot password?", new_password_path, class: "link link-hover text-sm" %>
      </div>
    </div>
  </div>
</div>
