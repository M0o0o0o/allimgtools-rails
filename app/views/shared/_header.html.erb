<header class="navbar bg-base-100 shadow-sm sticky top-0 z-50">
  <div class="navbar-start">
    <label for="nav-drawer" class="btn btn-ghost btn-sm drawer-button sm:hidden mr-1" aria-label="Open menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
    <%= link_to root_path, class: "btn btn-ghost text-xl font-bold tracking-tight" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      allimgtools
    <% end %>
  </div>

  <div class="navbar-end">
    <nav class="hidden sm:flex gap-1 items-center">
      <%= link_to "Image Compress", new_compress_path, class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors hover:bg-base-200 #{controller_name == 'compress' ? 'text-primary' : 'text-base-content/60 hover:text-base-content'}" %>
      <%= link_to "Image Resize", new_resize_path, class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors hover:bg-base-200 #{controller_name == 'resize' ? 'text-primary' : 'text-base-content/60 hover:text-base-content'}" %>
      <%= link_to "EXIF Remover", new_exif_path, class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors hover:bg-base-200 #{controller_name == 'exif' ? 'text-primary' : 'text-base-content/60 hover:text-base-content'}" %>
      <%= link_to "Image Rotate", new_rotate_path, class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors hover:bg-base-200 #{controller_name == 'rotate' ? 'text-primary' : 'text-base-content/60 hover:text-base-content'}" %>

      <%# Image Convert dropdown %>
      <div class="dropdown dropdown-end">
        <label tabindex="0"
               class="px-3 py-1.5 text-sm font-medium rounded-lg transition-colors hover:bg-base-200 cursor-pointer flex items-center gap-1 <%= controller_name == 'convert' ? 'text-primary' : 'text-base-content/60 hover:text-base-content' %>">
          Image Convert
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </label>
        <ul tabindex="0" class="dropdown-content menu menu-sm bg-base-100 rounded-xl shadow-lg z-50 w-44 p-1.5 mt-1 border border-base-200">
          <li><%= link_to "Image Converter", new_convert_path %></li>
          <li class="menu-title pt-2 pb-0.5">JPG</li>
          <li><%= link_to "JPG → PNG",  jpg_to_png_path %></li>
          <li><%= link_to "JPG → WebP", jpg_to_webp_path %></li>
          <li class="menu-title pt-2 pb-0.5">PNG</li>
          <li><%= link_to "PNG → JPG",  png_to_jpg_path %></li>
          <li><%= link_to "PNG → WebP", png_to_webp_path %></li>
          <li class="menu-title pt-2 pb-0.5">WebP</li>
          <li><%= link_to "WebP → JPG", webp_to_jpg_path %></li>
          <li><%= link_to "WebP → PNG", webp_to_png_path %></li>
        </ul>
      </div>
    </nav>
  </div>
</header>
