<div data-controller="chunk-upload"
     data-chunk-upload-success-path-value="<%= success_path %>"
     data-chunk-upload-task-id-value="<%= task.task_id %>">
  <form data-action="submit->chunk-upload#upload">

    <%# 드래그 앤 드롭 영역 %>
    <div class="border-2 border-dashed border-base-300 rounded-2xl p-8 sm:p-12 text-center cursor-pointer transition-colors hover:border-primary hover:bg-primary/5"
         data-chunk-upload-target="dropzone"
         data-action="click->chunk-upload#openFilePicker dragover->chunk-upload#onDragOver dragleave->chunk-upload#onDragLeave drop->chunk-upload#onDrop">
      <div class="flex flex-col items-center gap-3 pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <div>
          <p class="text-base font-semibold text-base-content">이미지를 드래그하거나 클릭하여 선택</p>
          <p class="text-sm text-base-content/50 mt-1">JPEG, PNG, GIF, WebP, AVIF · 최대 5MB / 파일</p>
        </div>
      </div>
      <input
        type="file"
        accept="image/jpeg,image/png,image/gif,image/webp,image/avif"
        multiple
        class="hidden"
        data-chunk-upload-target="input"
        data-action="change->chunk-upload#onFileChange"
      >
    </div>

    <%# 선택된 파일 미리보기 %>
    <ul class="mt-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 hidden" data-chunk-upload-target="preview">
    </ul>

    <%# 진행 상태 %>
    <div class="mt-6 hidden" data-chunk-upload-target="progressArea">
      <div class="flex justify-between text-sm mb-1">
        <span class="text-base-content/70" data-chunk-upload-target="status"></span>
      </div>
      <progress class="progress progress-primary w-full" data-chunk-upload-target="progress" value="0" max="100"></progress>
    </div>

    <%# 에러 메시지 %>
    <div class="alert alert-error mt-4 hidden" data-chunk-upload-target="errorAlert">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span data-chunk-upload-target="errorMessage"></span>
    </div>

    <div class="mt-6">
      <button type="submit" class="btn btn-primary w-full sm:w-auto" data-chunk-upload-target="submit" disabled>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
        </svg>
        업로드 시작
      </button>
    </div>

  </form>
</div>
